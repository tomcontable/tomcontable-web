    posthog.init('phc_nN8P2qzoCssbAcKvBFmuWY2t6EtBCgeu36BBZhM3tPBL', {
      api_host: 'https://us.i.posthog.com',
      defaults: '2026-05-30',
      person_profiles: 'identified_only',
    })
    // Exclusión del equipo: entrar UNA vez a tomcontable.cl/?soyTom en cada navegador
    // (computador y celular de cada uno). Ese dispositivo queda fuera de las estadísticas
    // para siempre. Para revertirlo: tomcontable.cl/?yaNoSoyTom
    if (location.search.indexOf('soyTom') > -1) {
      if (location.search.indexOf('yaNoSoyTom') > -1) {
        posthog.opt_in_capturing();
        alert('Este navegador vuelve a contar en las estadísticas.');
      } else {
        posthog.opt_out_capturing();
        alert('Listo: este navegador quedó fuera de las estadísticas de TomContable.');
      }
    }
  </script>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  {sugerencia && <SugerenciaFlotante origen={sugerencia} />}

  <!-- Luz que sigue al cursor (solo escritorio, muy sutil) -->
  <div id="luz-cursor" aria-hidden="true"></div>

  <!-- WhatsApp flotante -->
  <a class="wa-float" href="https://api.whatsapp.com/send/?phone=56964933110&text=Hola%20vengo%20desde%20la%20web" target="_blank" rel="noopener" aria-label="Hablar por WhatsApp" onclick="window.posthog&&window.posthog.capture('whatsapp_click',{cta_texto:'Botón flotante',mensaje:'Hola vengo desde la web',ubicacion:location.pathname})">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.523 5.263l-.999 3.648 3.966-1.041zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
  </a>
<script>
  // ===== Microinteracciones globales del sitio =====
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const punteroFino = window.matchMedia('(pointer: fine)').matches;

  // 1. Luz que sigue al cursor
  const luz = document.getElementById('luz-cursor');
  if (luz && punteroFino && !reduceMotion) {
    luz.classList.add('on');
    window.addEventListener('pointermove', (e) => {
      luz.style.setProperty('--lx', e.clientX + 'px');
      luz.style.setProperty('--ly', e.clientY + 'px');
    }, { passive: true });
  }

  // 2. Revelado suave al hacer scroll (con leve escalonado en grillas)
  if (!reduceMotion && 'IntersectionObserver' in window) {
    const grupos = ['.cards-3 > *', '.serv-grid > *', '.steps > *', '.cards-2 > *', '.rec-grid > *', '.grid > .card', '.pain-grid > *'];
    const sueltos = ['.sec-head', '.faq', '.tst-foot', '.about > *', '.planes > *', '.feat'];
    const objetivos = [];
    grupos.forEach((sel) => {
      document.querySelectorAll(sel).forEach((el, i) => { el.style.transitionDelay = Math.min(i * 70, 280) + 'ms'; objetivos.push(el); });
    });
    sueltos.forEach((sel) => document.querySelectorAll(sel).forEach((el) => objetivos.push(el)));
    const io = new IntersectionObserver((entradas) => {
      entradas.forEach((en) => {
        if (!en.isIntersecting) return;
        en.target.classList.add('rv-on');
        io.unobserve(en.target);
        // Al terminar el revelado, el elemento recupera sus propias transiciones (hover, etc.)
        setTimeout(() => { en.target.classList.remove('rv-ini', 'rv-on'); en.target.style.transitionDelay = ''; }, 760);
      });
    }, { threshold: 0.12 });
    objetivos.forEach((el) => { el.classList.add('rv-ini'); io.observe(el); });
  }

  // 3. Contadores animados: cualquier elemento con data-cifra
  if (!reduceMotion && 'IntersectionObserver' in window) {
    const fmt = (el, v) => {
      const dec = el.dataset.dec ? parseInt(el.dataset.dec) : 0;
      let s = el.dataset.miles ? Math.round(v).toLocaleString('es-CL') : v.toFixed(dec).replace('.', ',');
      el.textContent = (el.dataset.pref || '') + s + (el.dataset.suf || '');
    };
    const cio = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (!e.isIntersecting) return; cio.unobserve(e.target);
        const fin = parseFloat(e.target.dataset.cifra);
        const t0 = performance.now();
        const paso = (t) => {
          const p = Math.min((t - t0) / 1400, 1);
          fmt(e.target, fin * (1 - Math.pow(1 - p, 3)));
          if (p < 1) requestAnimationFrame(paso);
        };
        requestAnimationFrame(paso);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-cifra]').forEach((el) => cio.observe(el));
  }
</script>

<style is:global>
  /* Evita barras de scroll horizontales por elementos animados fuera de pantalla */
  html{overflow-x:clip}
  /* Luz del cursor */
  #luz-cursor{display:none}
  #luz-cursor.on{display:block;position:fixed;inset:0;pointer-events:none;z-index:38;background:radial-gradient(340px 340px at var(--lx,-500px) var(--ly,-500px),rgba(246,177,26,.075),transparent 70%)}
  /* Revelado al scroll */
  .rv-ini{opacity:0;transform:translateY(26px);transition:opacity .65s cubic-bezier(.2,.7,.2,1),transform .65s cubic-bezier(.2,.7,.2,1)}
  .rv-on{opacity:1;transform:none}
</style>
</body>
</html>

<style>
  .wa-float{position:fixed;right:22px;bottom:22px;z-index:60;background:var(--verde);width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 26px -6px rgba(30,158,87,.6);transition:.18s}
  .wa-float:hover{transform:scale(1.06)}
  .wa-float svg{width:32px;height:32px;color:#fff}
</style>
