---
import Base from '../layouts/Base.astro';
import CalculadoraIndicador from '../components/CalculadoraIndicador.astro';

const seo = {
  title: 'Calculadora UF a Pesos 2026 | Cuánto vale la UF hoy · TomContable',
  description: 'Convierte UF a pesos y pesos a UF con el valor de la UF de hoy o de cualquier fecha, actualizado desde el Banco Central. Calculadora gratis y simple de TomContable.',
  canonical: '/calculadora-uf',
};

const faqs = [
  { q: '¿Qué es la UF?', a: 'La Unidad de Fomento (UF) es una unidad de cuenta reajustable según la inflación. Su valor en pesos cambia todos los días. Se usa en Chile para créditos, arriendos, contratos y muchos montos tributarios y previsionales.' },
  { q: '¿Puedo ver el valor de la UF de una fecha pasada?', a: 'Sí. Esta calculadora te deja elegir la fecha con las flechas o el calendario, y toma el valor oficial de la UF de ese día, no solo el de hoy. Es útil para arriendos, contratos o deudas pactadas en otra fecha.' },
  { q: '¿Cada cuánto cambia el valor de la UF?', a: 'Todos los días. El Banco Central de Chile publica el valor diario, que se reajusta según la variación del IPC del mes anterior.' },
  { q: '¿De dónde sale el valor que usa esta calculadora?', a: 'Del valor oficial publicado por el Banco Central de Chile. Se consulta en línea, así que el resultado siempre usa la UF vigente para la fecha seleccionada.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((it) => ({ '@type': 'Question', name: it.q, acceptedAnswer: { '@type': 'Answer', text: it.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Calculadora UF a Pesos', applicationCategory: 'FinanceApplication', operatingSystem: 'Web', inLanguage: 'es-CL', url: 'https://tomcontable.cl/calculadora-uf', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CLP' }, publisher: { '@type': 'Organization', name: 'TomContable' } };
---
<Base {...seo} schema={[appSchema, faqSchema]}>
  <CalculadoraIndicador
    codigo="uf"
    unidadLabel="UF"
    eyebrow="Herramienta gratis"
    h1="Calculadora UF a pesos"
    lead="Convierte de UF a pesos y de pesos a UF al instante, con el valor de la UF de hoy o de la fecha que elijas, según el Banco Central."
    ico={`<path d="M22 100V20" stroke="#1E2F73" stroke-width="3.5" stroke-linecap="round"/><path d="M22 100h78" stroke="#1E2F73" stroke-width="3.5" stroke-linecap="round"/><path d="M34 84l18-20 16 12 26-34" stroke="#F6B11A" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="M80 42h14v14" stroke="#F6B11A" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>`}
    intro={[
      'Escribe un monto en UF y verás cuántos pesos son, o escribe pesos y verás a cuántas UF equivale. Por defecto usa la UF de hoy, pero puedes moverte día a día con las flechas o abrir el calendario para cualquier fecha.',
      'La UF aparece en arriendos, créditos, planes de salud, multas, topes imponibles y varios montos tributarios. Tener claro el equivalente en pesos te ayuda a decidir con el número real sobre la mesa.',
    ]}
    faqs={faqs}
    ctaTitulo="¿Tus impuestos o tu contabilidad te tienen en UF y no sabes por dónde partir?"
    ctaTexto="Eso es lo nuestro. Cuéntanos de tu empresa por WhatsApp y te orientamos en simple, sin compromiso."
    ctaMensaje="Hola vengo desde la calculadora UF"
  />
</Base>
