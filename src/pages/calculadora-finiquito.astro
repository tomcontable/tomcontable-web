---
import Base from '../layouts/Base.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';

const seo = {
  title: 'Calculadora de Finiquito en Chile | Simulador gratis · TomContable',
  description: 'Calcula el finiquito en Chile: vacaciones proporcionales, indemnización por años de servicio y mes de aviso. Gratis, simple y con el valor de la UF al día. Por TomContable.',
  canonical: '/calculadora-finiquito',
};

const faqs = [
  { q: '¿Qué incluye el finiquito que calcula esta herramienta?', a: 'Calcula los conceptos más comunes: vacaciones pendientes o proporcionales, indemnización por años de servicio (cuando corresponde por necesidades de la empresa), indemnización sustitutiva del aviso previo y la remuneración pendiente. Además puedes sumar otros haberes y restar descuentos a mano. Es una estimación referencial.' },
  { q: '¿Es un cálculo oficial o certificado?', a: 'No. Es una herramienta de apoyo para tener una estimación rápida. Cada finiquito tiene detalles y casos especiales que deben revisarse. Para tu finiquito definitivo, escríbenos y lo revisamos contigo.' },
  { q: '¿Por qué la indemnización por años de servicio a veces sale cero?', a: 'Porque esa indemnización aplica principalmente cuando el término es por necesidades de la empresa y existe al menos un año de servicio. En causales como renuncia o mutuo acuerdo, no corresponde. Las vacaciones, en cambio, siempre se pagan.' },
  { q: '¿Qué es el tope de 11 años y el de 90 UF?', a: 'La indemnización por años de servicio se paga por cada año trabajado (y fracción superior a seis meses), con un tope legal de 11 años. Además, la base de cálculo tiene un tope de 90 UF. La calculadora aplica ambos topes.' },
  { q: '¿Cómo cuento los días inhábiles de las vacaciones?', a: 'Con un calendario a la vista, cuenta desde el día del finiquito hacia adelante los días hábiles pendientes y suma los sábados, domingos y festivos que caen dentro de ese período. Ese número va en el campo de días inhábiles.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((it) => ({ '@type': 'Question', name: it.q, acceptedAnswer: { '@type': 'Answer', text: it.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Calculadora de Finiquito', applicationCategory: 'FinanceApplication', operatingSystem: 'Web', inLanguage: 'es-CL', url: 'https://tomcontable.cl/calculadora-finiquito', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CLP' }, publisher: { '@type': 'Organization', name: 'TomContable' } };
---
<Base {...seo} schema={[appSchema, faqSchema]}>

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Herramienta gratis</p>
      <h1>Calculadora de finiquito</h1>
      <p class="lead">Estima el finiquito en Chile en un minuto: vacaciones, indemnización por años de servicio y mes de aviso, con el valor de la UF al día.</p>
    </div>
  </section>

  <section class="sec">
    <div class="wrap calc-wrap">

      <p class="aviso-top">Esta es una <strong>estimación referencial</strong>, no un cálculo certificado. Hay casos especiales que conviene revisar. ¿Necesitas tu finiquito bien hecho? <a href="https://api.whatsapp.com/send/?phone=56964933110&text=Hola%20vengo%20desde%20la%20calculadora%20de%20finiquito" target="_blank" rel="noopener">Escríbenos</a>.</p>

      <div class="grid">

        <form class="panel form" id="fin-form" autocomplete="off">
          <h2>Datos</h2>

          <label class="f">
            <span>Causal de término</span>
            <select id="causal">
              <option value="Necesidades de la Empresa">Necesidades de la empresa</option>
              <option value="Renuncia del Trabajador">Renuncia del trabajador</option>
              <option value="Mutuo Acuerdo">Mutuo acuerdo</option>
              <option value="Fin Plazo Convenido">Fin de plazo convenido</option>
            </select>
          </label>

          <div class="f2">
            <label class="f"><span>Fecha de inicio del contrato</span><input type="date" id="f-inicio" /></label>
            <label class="f"><span>Último día trabajado</span><input type="date" id="f-fin" /></label>
          </div>

          <label class="f"><span>Sueldo base mensual</span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="sueldo" placeholder="0" /></div></label>

          <label class="f"><span>Bono imponible <em>(promedio últimos 3 meses)</em> <span class="hint" tabindex="0" data-tip="Promedio mensual de los bonos imponibles de los últimos 3 meses. Si no tienes bonos, déjalo en 0.">?</span></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="bonos" placeholder="0" /></div></label>

          <div class="f2">
            <label class="f">
              <span>Gratificación <span class="hint" tabindex="0" data-tip="Si el trabajador recibe gratificación, se calcula como el 25% del sueldo con tope mensual legal. Solo afecta la base de la indemnización.">?</span></span>
              <select id="grat-on"><option value="si">Sí, incluir</option><option value="no">No incluir</option></select>
            </label>
            <label class="f"><span>Gratificación calculada</span><div class="inp ro"><i></i><input type="text" id="grat-view" disabled placeholder="automático" /></div></label>
          </div>

          <div class="f2">
            <label class="f"><span>Asignación de colación <em>(mensual)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="colacion" placeholder="0" /></div></label>
            <label class="f"><span>Asignación de movilización <em>(mensual)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="moviliz" placeholder="0" /></div></label>
          </div>

          <h2>Vacaciones</h2>
          <div class="f2">
            <label class="f"><span>N° de días de vacaciones tomados <em>(durante toda la vigencia del contrato)</em> <span class="hint" tabindex="0" data-tip="Total de días hábiles de vacaciones que el trabajador ya usó durante todo el contrato. Se descuentan de las vacaciones acumuladas.">?</span></span><input type="text" inputmode="decimal" id="vac-tomadas" placeholder="0" /></label>
            <label class="f"><span>Días inhábiles en las vacaciones pendientes <em>(sáb, dom y festivos)</em> <span class="hint" tabindex="0" data-tip="Con calendario en mano, desde el día del finiquito hacia adelante: cuenta los días hábiles pendientes y suma los sábados, domingos y festivos que caen dentro de ese período.">?</span></span><input type="text" inputmode="decimal" id="vac-inhabiles" placeholder="0" /></label>
          </div>

          <h2>Otros y ajustes</h2>
          <label class="f" id="aviso-wrap">
            <span>¿El empleador avisó con 30 días de anticipación?</span>
            <select id="aviso">
              <option value="si">Sí, avisó con 30 días</option>
              <option value="no">No avisó (corresponde mes de aviso)</option>
            </select>
          </label>
          <label class="f" id="pactada-wrap">
            <span>Indemnización pactada <em>(acuerdo entre las partes)</em> <span class="hint" tabindex="0" data-tip="En un finiquito por mutuo acuerdo, las partes pueden pactar libremente una indemnización. Ingresa el monto acordado.">?</span></span>
            <div class="inp"><i>$</i><input type="text" inputmode="numeric" id="pactada" placeholder="0" /></div>
          </label>
          <label class="f" id="afc-wrap">
            <span>Descuento AFC <em>(aporte del empleador)</em> <span class="hint" tabindex="0" data-tip="En necesidades de la empresa con más de un año, el empleador puede descontar de la indemnización por años de servicio la parte financiada por su aporte al seguro de cesantía (AFC). Ingresa ese monto para restarlo.">?</span></span>
            <div class="inp"><i>$</i><input type="text" inputmode="numeric" id="afc" placeholder="0" /></div>
          </label>
          <label class="f"><span>Remuneración pendiente del último período</span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="rem-pendiente" placeholder="0" /></div></label>
          <label class="f"><span>Otros haberes a agregar <em>(a mano)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="otros-haberes" placeholder="0" /></div></label>
          <label class="f"><span>Descuentos a restar <em>(a mano)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="descuentos" placeholder="0" /></div></label>
        </form>

        <div class="panel result" id="result">
          <div class="wm" aria-hidden="true"></div>
          <h2>Resumen del finiquito</h2>
          <div class="r-rows" id="r-rows"></div>
          <div class="r-total">
            <span>Total estimado a pagar</span>
            <strong id="r-total">$0</strong>
          </div>
          <p class="r-meta" id="r-meta"></p>
          <div class="r-cta">
            <BotonWhatsApp texto="Quiero que revisen mi finiquito" mensaje="Hola vengo desde la calculadora de finiquito y quiero que revisen mi caso" />
          </div>
          <div class="r-mail">
            <button type="button" class="mail-toggle" id="mail-toggle">Recibir esta estimación en PDF a mi correo</button>
            <div class="mail-box" id="mail-box" hidden>
              <input class="inp-solo" id="mail-nombre" type="text" placeholder="Tu nombre" autocomplete="given-name" />
              <div class="inp"><i>@</i><input type="email" id="mail-input" placeholder="tucorreo@ejemplo.cl" /></div>
              <input class="hp" id="mail-website" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <label class="mail-check"><input type="checkbox" id="mail-consent" /><span>Acepto recibir mi estimación en PDF y, cada cierto tiempo, contenido útil de TomContable. Puedo darme de baja cuando quiera. <a href="/privacidad" target="_blank" rel="noopener">Política de privacidad</a>.</span></label>
              <button type="button" class="btn btn-amber" id="mail-send">Enviarme el PDF</button>
              <p class="mail-msg" id="mail-msg" role="status"></p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="sec-cert">
    <div class="wrap angosto">
      <div class="cert">
        <div class="cert-txt">
          <h2>¿Lo quieres como documento formal y certificado?</h2>
          <p>Con los datos que nos entregues, te emitimos el cálculo de tu finiquito en un <strong>documento formal, certificado por TomContable</strong>, listo para presentar o respaldar. No es una reunión ni una asesoría: es tu cálculo, hecho y certificado por contadores, al toque. <strong>Solo 1 UF + IVA.</strong></p>
        </div>
        <BotonWhatsApp texto="Quiero mi finiquito certificado · 1 UF + IVA" mensaje="Hola, quiero el cálculo de mi finiquito certificado por TomContable (1 UF + IVA), vengo desde la calculadora" />
      </div>
    </div>
  </section>

  <section class="sec-legal">
    <div class="wrap angosto">
      <p class="legal-fin">Este cálculo es solo una estimación referencial generada con los datos ingresados por el usuario. No constituye finiquito oficial, asesoría laboral ni validación de TomContable. El monto final debe ser revisado según contrato, antecedentes laborales, remuneraciones, vacaciones, causales aplicables y normativa vigente.</p>
    </div>
  </section>

  <section class="sec sec-texto">
    <div class="wrap angosto">
      <h2>Cómo funciona</h2>
      <p>Completa los datos del contrato y la calculadora estima el finiquito con las reglas generales: las vacaciones se pagan siempre (proporcionales a los meses trabajados), la indemnización por años de servicio aplica cuando el término es por necesidades de la empresa, y el mes de aviso se paga cuando no hubo aviso con 30 días de anticipación. Usamos el valor de la UF del día para el tope legal de la base de cálculo.</p>
      <p>Es una estimación de apoyo. Cada caso real puede tener detalles (bonos, comisiones, semanas corridas, licencias, anticipos, descuentos) que conviene revisar. Si quieres tu finiquito bien calculado y respaldado, lo vemos contigo.</p>

      <h2 id="faq">Preguntas frecuentes</h2>
      <div class="faq">
        {faqs.map((it) => (
          <details>
            <summary>{it.q}<span class="plus">+</span></summary>
            <div class="ans">{it.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cierre">
    <div class="wrap">
      <h2>¿Necesitas un finiquito bien hecho, o calcular las remuneraciones de tu pyme?</h2>
      <p>Te ayudamos con remuneraciones, finiquitos y todo lo laboral de tu empresa. Conversemos por WhatsApp, sin compromiso.</p>
      <div class="cta-row center"><BotonWhatsApp texto="Hablar por WhatsApp" mensaje="Hola vengo desde la calculadora de finiquito" /></div>
    </div>
  </section>

</Base>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
  const SUELDO_MINIMO = 539000; // parámetro: actualizar cuando cambie el sueldo mínimo
  let UF = 40746.28;            // se reemplaza por el valor en vivo

  const fmt0 = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
  const $ = (id) => document.getElementById(id);

  const num = (id) => {
    const v = $(id).value;
    if (!v) return 0;
    const n = parseFloat(String(v).replace(/\./g, '').replace(/,/g, '.').replace(/[^\d.]/g, ''));
    return isFinite(n) ? n : 0;
  };
  const parseFecha = (id) => {
    const v = $(id).value;
    if (!v) return null;
    const [y, m, d] = v.split('-').map(Number);
    if (!y || !m || !d) return null;
    return new Date(y, m - 1, d);
  };
  const edate = (d, months) => new Date(d.getFullYear(), d.getMonth() + months, d.getDate());
  const difMeses = (d1, d2) => {
    let m = (d2.getFullYear() - d1.getFullYear()) * 12 + (d2.getMonth() - d1.getMonth());
    if (d2.getDate() < d1.getDate()) m--;
    return m;
  };
  const diffDias = (a, b) => Math.round((b - a) / 86400000);
  const aniosServicio = (meses) => {
    const umbrales = [12, 18, 30, 42, 54, 66, 78, 90, 102, 114, 126, 138, 150];
    let c = 0; umbrales.forEach((u) => { if (meses >= u) c++; });
    return Math.min(c, 11);
  };
  const dias = (n) => (Math.round(n * 100) / 100).toLocaleString('es-CL') + (n === 1 ? ' día' : ' días');

  const calcular = () => {
    const causal = $('causal').value;
    const di = parseFecha('f-inicio');
    const df = parseFecha('f-fin');
    const sueldo = num('sueldo');
    const bonos = num('bonos');
    const gratOn = $('grat-on').value === 'si';
    const colacion = num('colacion');
    const moviliz = num('moviliz');
    const vacTomadas = num('vac-tomadas');
    const vacInhabiles = num('vac-inhabiles');
    const aviso = $('aviso').value;
    const pactada = num('pactada');
    const afc = num('afc');
    const remPend = num('rem-pendiente');
    const otros = num('otros-haberes');
    const descuentos = num('descuentos');

    const esNecesidades = causal === 'Necesidades de la Empresa';
    const esMutuo = causal === 'Mutuo Acuerdo';

    const rows = $('r-rows');

    // base para saber años (necesita fechas)
    let meses = 0, anios = 0;
    if (di && df && df > di) { meses = difMeses(di, df); anios = aniosServicio(meses); }

    // mostrar/ocultar campos condicionales
    $('aviso-wrap').style.display = esNecesidades ? '' : 'none';
    $('pactada-wrap').style.display = esMutuo ? '' : 'none';
    $('afc-wrap').style.display = (esNecesidades && anios >= 1) ? '' : 'none';

    if (!di || !df || df <= di || sueldo <= 0) {
      rows.innerHTML = '<p class="r-empty">Completa la causal, las fechas y el sueldo base para ver la estimación.</p>';
      $('r-total').textContent = '$0';
      $('r-meta').textContent = '';
      $('grat-view').value = '';
      return;
    }

    const diasAdic = diffDias(edate(di, meses), df);

    // Vacaciones (nunca negativas)
    const vacAntes = Math.round((meses * 1.25 + diasAdic * 0.04167) * 100) / 100;
    const vacPend = Math.max(0, vacAntes - vacTomadas);
    const totalDiasVac = vacPend > 0 ? vacPend + vacInhabiles : 0;
    const baseVac = sueldo + bonos;
    const remDiaria = baseVac / 30;
    const pagoVac = totalDiasVac * remDiaria;

    // Gratificación y base de indemnización
    const topeGrat = (SUELDO_MINIMO * 4.75) / 12;
    const grat = gratOn ? Math.min(baseVac * 0.25, topeGrat) : 0;
    $('grat-view').value = gratOn ? fmt0.format(Math.round(grat)) : 'No incluida';

    const baseIndem = Math.min(baseVac + grat + colacion + moviliz, UF * 90);
    const indemAnios = esNecesidades ? baseIndem * anios : 0;
    const indemAviso = (esNecesidades && aviso === 'no') ? baseIndem : 0;
    const indemPactada = esMutuo ? pactada : 0;
    const descAFC = (esNecesidades && anios >= 1) ? afc : 0;

    const total = indemAnios + indemAviso + indemPactada + Math.max(pagoVac, 0) + remPend + otros - descAFC - descuentos;

    // filas: {concepto, detalle, monto, resta}
    const filas = [];
    if (esNecesidades) filas.push(['Indemnización por años de servicio', anios >= 1 ? anios + (anios === 1 ? ' año' : ' años') : 'menos de 1 año', indemAnios, false]);
    if (esNecesidades && indemAviso > 0) filas.push(['Indemnización sustitutiva del aviso previo', '1 mes', indemAviso, false]);
    if (esMutuo && indemPactada > 0) filas.push(['Indemnización pactada', 'acuerdo entre las partes', indemPactada, false]);
    filas.push(['Vacaciones pendientes y/o proporcionales', dias(totalDiasVac), Math.max(pagoVac, 0), false]);
    if (remPend > 0) filas.push(['Remuneración pendiente del período', '', remPend, false]);
    if (otros > 0) filas.push(['Otros haberes', '', otros, false]);
    if (descAFC > 0) filas.push(['Descuento AFC (aporte empleador)', '', descAFC, true]);
    if (descuentos > 0) filas.push(['Descuentos', '', descuentos, true]);

    rows.innerHTML = filas.map((f) => {
      const monto = (f[3] ? '−' : '') + fmt0.format(Math.round(f[2]));
      const det = f[1] ? `<span class="r-d">${f[1]}</span>` : '';
      return `<div class="r-row"><div class="r-info"><span class="r-c">${f[0]}</span>${det}</div><span class="r-v${f[3] ? ' neg' : ''}">${monto}</span></div>`;
    }).join('');

    $('r-total').textContent = fmt0.format(Math.round(total));
    $('r-meta').textContent = `Antigüedad: ${meses} ${meses === 1 ? 'mes' : 'meses'} (${anios} ${anios === 1 ? 'año' : 'años'} para indemnización). UF usada: ${fmt0.format(UF)}.`;
  };

  $('fin-form').addEventListener('input', calcular);
  $('fin-form').addEventListener('change', calcular);

  fetch('https://mindicador.cl/api/uf')
    .then((r) => r.json())
    .then((data) => { if (data && data.serie && data.serie[0]) UF = data.serie[0].valor; calcular(); })
    .catch(() => calcular());

  // Precarga del logo para el PDF
  let logoImg = null;
  (() => { const im = new Image(); im.crossOrigin = 'anonymous'; im.onload = () => { logoImg = im; }; im.src = '/img/logo-tomcontable.png'; })();

  // Genera el PDF imprimible y devuelve el base64 (sin prefijo data:)
  const buildPDFBase64 = (filas, total, meta) => {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'mm', format: 'a4' });
    const W = 210, M = 18;
    // Marca de agua diagonal
    if (doc.setGState) doc.setGState(new doc.GState({ opacity: 0.10 }));
    doc.setTextColor(19, 35, 95); doc.setFont('helvetica', 'bold'); doc.setFontSize(16);
    for (let yy = 45; yy < 290; yy += 52) for (let xx = -5; xx < 215; xx += 92) doc.text('Estimación no certificada', xx, yy, { angle: 30 });
    if (doc.setGState) doc.setGState(new doc.GState({ opacity: 1 }));
    // Encabezado
    if (logoImg) { try { doc.addImage(logoImg, 'PNG', M, 13, 45, 11); } catch (e) {} }
    doc.setTextColor(30, 47, 115); doc.setFont('helvetica', 'bold'); doc.setFontSize(18);
    doc.text('Estimación de finiquito', M, 38);
    doc.setFont('helvetica', 'normal'); doc.setFontSize(9); doc.setTextColor(139, 147, 179);
    doc.text('Generada el ' + new Date().toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' }), M, 44);
    // Filas
    let y = 56;
    doc.setDrawColor(230, 232, 240);
    filas.forEach((f) => {
      doc.setTextColor(51, 56, 74); doc.setFont('helvetica', 'normal'); doc.setFontSize(11);
      doc.text(f.c, M, y);
      if (f.d) { doc.setFontSize(8.5); doc.setTextColor(139, 147, 179); doc.text(f.d, M, y + 4.5); }
      doc.setFont('helvetica', 'bold'); doc.setFontSize(11);
      doc.setTextColor(f.neg ? 176 : 19, f.neg ? 54 : 35, f.neg ? 54 : 95);
      doc.text(f.v, W - M, y, { align: 'right' });
      y += f.d ? 12 : 9;
      doc.line(M, y - 3, W - M, y - 3);
    });
    // Total
    y += 2;
    doc.setFillColor(30, 47, 115); doc.roundedRect(M, y, W - 2 * M, 14, 2, 2, 'F');
    doc.setTextColor(207, 214, 234); doc.setFont('helvetica', 'normal'); doc.setFontSize(10);
    doc.text('Total estimado a pagar', M + 5, y + 9);
    doc.setTextColor(246, 177, 26); doc.setFont('helvetica', 'bold'); doc.setFontSize(15);
    doc.text(total, W - M - 5, y + 9.5, { align: 'right' });
    y += 20;
    if (meta) { doc.setFont('helvetica', 'normal'); doc.setFontSize(8.5); doc.setTextColor(139, 147, 179); doc.text(meta, M, y); y += 8; }
    // Descargo
    const disc = 'Este cálculo es solo una estimación referencial generada con los datos ingresados por el usuario. No constituye finiquito oficial, asesoría laboral ni validación de TomContable. El monto final debe ser revisado según contrato, antecedentes laborales, remuneraciones, vacaciones, causales aplicables y normativa vigente.';
    doc.setFont('helvetica', 'normal'); doc.setFontSize(8); doc.setTextColor(120, 120, 130);
    const lines = doc.splitTextToSize(disc, W - 2 * M);
    doc.text(lines, M, y);
    // Pie
    doc.setTextColor(139, 147, 179); doc.setFontSize(8.5);
    doc.text('TomContable · Más que contabilidad, tranquilidad · tomcontable.cl · WhatsApp +56 9 6493 3110', M, 287);
    return doc.output('datauristring').split(',')[1];
  };

  // Enviar estimación en PDF + capturar lead
  $('mail-toggle').addEventListener('click', () => {
    const box = $('mail-box'); box.hidden = !box.hidden;
    if (!box.hidden) $('mail-nombre').focus();
  });
  $('mail-send').addEventListener('click', async () => {
    const msg = $('mail-msg');
    const email = $('mail-input').value.trim();
    const nombre = $('mail-nombre').value.trim();
    const consent = $('mail-consent').checked;
    const website = $('mail-website').value; // honeypot
    const filasEls = [...document.querySelectorAll('#r-rows .r-row')];
    if (!filasEls.length || $('r-total').textContent === '$0') { msg.textContent = 'Primero completa el cálculo arriba.'; return; }
    if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { msg.textContent = 'Revisa tu correo, no parece válido.'; return; }
    if (!consent) { msg.textContent = 'Marca la casilla para poder enviarte el PDF.'; return; }
    const filas = filasEls.map((r) => ({
      c: r.querySelector('.r-c')?.textContent || '',
      d: r.querySelector('.r-d')?.textContent || '',
      v: r.querySelector('.r-v')?.textContent || '',
      neg: r.querySelector('.r-v')?.classList.contains('neg') || false,
    }));
    const total = $('r-total').textContent;
    const meta = $('r-meta').textContent;
    let pdf = '';
    try { if (window.jspdf) pdf = buildPDFBase64(filas, total, meta); } catch (e) { pdf = ''; }
    msg.textContent = 'Enviando…';
    $('mail-send').disabled = true;
    try {
      const resp = await fetch('/api/enviar-finiquito', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email, nombre, consent, website, total, meta, filas, pdf }),
      });
      const j = await resp.json();
      msg.textContent = j && j.ok ? '¡Listo! Te enviamos el PDF a tu correo (revisa también spam).' : 'No pudimos enviarlo ahora. Inténtalo en un rato.';
    } catch (e) {
      msg.textContent = 'No pudimos enviarlo ahora. Inténtalo en un rato.';
    }
    $('mail-send').disabled = false;
  });

  // Tooltips de ayuda (?) : clic para fijar, hover para mostrar, se cierran al salir
  document.querySelectorAll('.hint').forEach((h) => {
    h.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); document.querySelectorAll('.hint.show').forEach((o) => { if (o !== h) o.classList.remove('show'); }); h.classList.toggle('show'); });
    h.addEventListener('mouseleave', () => h.classList.remove('show'));
  });
  document.addEventListener('click', (e) => { if (!e.target.closest('.hint')) document.querySelectorAll('.hint.show').forEach((o) => o.classList.remove('show')); });

  calcular();
</script>

