---
import Base from '../../layouts/Base.astro';
import BotonWhatsApp from '../../components/BotonWhatsApp.astro';
import { getCollection } from 'astro:content';

const seo = {
  title: 'Blog de TomContable · Contabilidad e impuestos en simple para pymes',
  description: 'Guías claras sobre contabilidad, impuestos, el SII y cómo llevar tu empresa al día en Chile. Escritas en simple para emprendedores y pymes.',
};

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmtFecha = (d) =>
  d.toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' });

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://tomcontable.cl/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tomcontable.cl/blog/" }
  ]
};
---
<Base {...seo} schema={[breadcrumb]}>

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Blog</p>
      <h1>Impuestos y contabilidad, explicados en simple.</h1>
      <p class="lead">Guías directas para emprendedores y pymes en Chile. Sin letra chica ni palabras difíciles. Si después de leer te queda una duda, escríbenos por WhatsApp.</p>
      <div class="cta-row"><BotonWhatsApp texto="Hablar por WhatsApp" mensaje="Hola vengo desde la web" /></div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      {posts.length === 0 ? (
        <p class="vacio">Pronto vamos a publicar las primeras guías aquí.</p>
      ) : (
        <div class="grid">
          {posts.map((post) => (
            <a class="card" href={`/blog/${post.slug}`}>
              <p class="card-tag">{post.data.keyword}</p>
              <h2>{post.data.title}</h2>
              <p class="card-lead">{post.data.lead}</p>
              <p class="card-meta">{fmtFecha(post.data.pubDate)}<span class="leer">Leer guía</span></p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cierre">
    <div class="wrap">
      <h2>¿Tienes una duda que no está acá?</h2>
      <p>Cuéntanos qué está pasando con tu empresa y te orientamos en simple.</p>
      <div class="cta-row center"><BotonWhatsApp texto="Hablar por WhatsApp" mensaje="Hola vengo desde la web" /></div>
    </div>
  </section>

</Base>

<style>
  .hero{background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%);padding:60px 0}
  .hero h1{font-size:38px;font-weight:800;letter-spacing:-.5px}
  .hero .lead{font-size:17.5px;color:#444a63;margin:16px 0 24px;max-width:60ch}
  .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .cta-row.center{justify-content:center}
  .sec{padding:56px 0}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:24px}
  .card{background:#fff;border:1px solid var(--linea);border-radius:16px;padding:28px;display:flex;flex-direction:column;transition:.18s;box-shadow:0 6px 18px -14px rgba(19,35,95,.4)}
  .card:hover{transform:translateY(-3px);border-color:#c9cfe2;box-shadow:0 16px 30px -18px rgba(19,35,95,.5)}
  .card-tag{font-family:'Montserrat';font-weight:700;font-size:11.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--verde);margin-bottom:12px}
  .card h2{font-size:21px;font-weight:800;line-height:1.25;margin-bottom:10px}
  .card-lead{color:#555;font-size:15px;flex-grow:1}
  .card-meta{margin-top:18px;padding-top:16px;border-top:1px solid var(--linea);display:flex;justify-content:space-between;align-items:center;font-size:13.5px;color:var(--gris)}
  .leer{font-family:'Montserrat';font-weight:700;color:var(--azul);font-size:13.5px}
  .vacio{color:var(--gris);font-size:17px}
  .cierre{background:linear-gradient(150deg,var(--azul),var(--azul-prof));color:#fff;text-align:center;padding:66px 24px}
  .cierre h2{color:#fff;font-size:28px;font-weight:800}
  .cierre p{color:#cfd6ea;font-size:17px;margin:14px auto 26px;max-width:52ch}
  @media(max-width:640px){ .hero h1{font-size:30px} }
</style>
