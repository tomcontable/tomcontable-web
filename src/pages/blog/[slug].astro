---
import Base from '../../layouts/Base.astro';
import BotonWhatsApp from '../../components/BotonWhatsApp.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const d = post.data;

const url = `https://tomcontable.cl/blog/${post.slug}`;
const fmtFecha = (x) =>
  x.toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' });

// Tiempo de lectura estimado a partir del cuerpo
const palabras = post.body.trim().split(/\s+/).length;
const minutos = Math.max(1, Math.round(palabras / 200));

// Artículos relacionados: los 3 más recientes, sin contar este mismo.
const relacionados = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const seo = {
  title: d.seoTitle,
  description: d.description,
  canonical: `/blog/${post.slug}`,
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": d.title,
  "description": d.description,
  "datePublished": d.pubDate.toISOString(),
  "dateModified": (d.updatedDate ?? d.pubDate).toISOString(),
  "inLanguage": "es-CL",
  "mainEntityOfPage": url,
  "image": "https://tomcontable.cl/img/og-tomcontable.jpg",
  "author": {
    "@type": "Person",
    "@id": "https://tomcontable.cl/#tomas",
    "name": "Tomás Gómez Fuenzalida",
    "jobTitle": "Contador Colegiado",
    "url": "https://tomcontable.cl/sobre-tomcontable"
  },
  "publisher": {
    "@type": "Organization",
    "name": "TomContable",
    "logo": { "@type": "ImageObject", "url": "https://tomcontable.cl/img/logo-tomcontable-horizontal.png", "width": 132, "height": 60 }
  }
};

const faqSchema = d.faqs.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": d.faqs.map((it) => ({
    "@type": "Question",
    "name": it.q,
    "acceptedAnswer": { "@type": "Answer", "text": it.a }
  }))
} : null;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://tomcontable.cl/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tomcontable.cl/blog/" },
    { "@type": "ListItem", "position": 3, "name": d.title, "item": url }
  ]
};

const schema = [articleSchema, breadcrumb, ...(faqSchema ? [faqSchema] : [])];
---
<Base {...seo} type="article" schema={schema}>

  <article>
    <header class="cab">
      <div class="wrap angosto">
        <p class="ruta"><a href="/blog/">Blog</a><span>/</span>{d.keyword}</p>
        <h1>{d.title}</h1>
        <p class="lead">{d.lead}</p>
        <div class="meta">
          <img src="/img/foto-tom.jpg" alt="Tom, Contador Colegiado y fundador de TomContable" width="36" height="36" />
          <span>Por Tom · {fmtFecha(d.pubDate)}{d.updatedDate && d.updatedDate.getTime() !== d.pubDate.getTime() && ` · actualizado el ${fmtFecha(d.updatedDate)}`} · {minutos} min de lectura</span>
        </div>
      </div>
    </header>

    <div class="cuerpo">
      <div class="wrap angosto">
        <div class="prosa">
          <Content />
        </div>

        <div class="cta-inline">
          <p>¿Quieres que veamos tu caso en concreto?</p>
          <BotonWhatsApp texto={d.ctaTexto} mensaje={d.ctaMensaje} />
        </div>

        {d.faqs.length > 0 && (
          <section class="faqs">
            <h2>Preguntas frecuentes</h2>
            <div class="faq">
              {d.faqs.map((it) => (
                <details>
                  <summary>{it.q}<span class="plus">+</span></summary>
                  <div class="ans">{it.a}</div>
                </details>
              ))}
            </div>
          </section>
        )}

        <aside class="relacionado">
          <p class="rel-label">Servicio relacionado</p>
          <a class="rel-link" href={d.servicioHref}>{d.servicioTexto}</a>
        </aside>
      </div>
    </div>
  </article>

  {relacionados.length > 0 && (
    <section class="mas">
      <div class="wrap">
        <p class="eyebrow">Sigue leyendo</p>
        <h2>Otras guías que te pueden servir</h2>
        <div class="grid">
          {relacionados.map((rp) => (
            <a class="card" href={`/blog/${rp.slug}`}>
              <p class="card-tag">{rp.data.keyword}</p>
              <h3>{rp.data.title}</h3>
              <p class="card-lead">{rp.data.lead}</p>
              <p class="card-meta">
                <span>{fmtFecha(rp.data.pubDate)}</span>
                <span class="leer">Leer guía<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="cierre">
    <div class="wrap">
      <p class="cierre-eyebrow">El siguiente paso es un mensaje</p>
      <h2>Más que contabilidad, tranquilidad.</h2>
      <p>Cuéntanos de tu empresa por WhatsApp y te orientamos en simple, sin compromiso.</p>
      <div class="cta-row center"><BotonWhatsApp texto={d.ctaTexto} mensaje={d.ctaMensaje} /></div>
    </div>
  </section>

</Base>

<style>
  .cab{position:relative;background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%);padding:54px 0 44px;overflow:hidden}
  .cab::before{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(30,47,115,.055) 1px,transparent 1px);background-size:26px 26px;pointer-events:none;mask-image:radial-gradient(65% 65% at 82% 15%,#000 10%,transparent 72%)}
  .cab .wrap{position:relative;z-index:2}
  .angosto{max-width:760px}
  .ruta{font-family:'Montserrat';font-weight:600;font-size:13px;color:var(--gris);margin-bottom:16px;display:flex;gap:8px;align-items:center}
  .ruta a{color:var(--azul)}
  .ruta span{color:#c2c7d6}
  .cab h1{font-size:36px;font-weight:800;letter-spacing:-.5px;line-height:1.12}
  .cab .lead{font-size:18px;color:#444a63;margin:18px 0 18px}
  .meta{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--gris)}
  .meta img{width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0}

  .cuerpo{padding:48px 0}

  /* Estilos del texto del articulo (markdown renderizado) */
  .prosa{font-size:17px;color:#33384a;line-height:1.75}
  .prosa :global(h2){font-size:25px;font-weight:800;margin:38px 0 14px;letter-spacing:-.3px}
  .prosa :global(h3){font-size:20px;font-weight:700;margin:28px 0 10px}
  .prosa :global(p){margin-bottom:18px}
  .prosa :global(ul),.prosa :global(ol){margin:0 0 18px 22px}
  .prosa :global(li){margin-bottom:8px}
  .prosa :global(a){color:var(--azul);font-weight:600;text-decoration:underline;text-underline-offset:2px}
  .prosa :global(a:hover){color:var(--azul-prof)}
  .prosa :global(strong){color:var(--azul)}

  .cta-inline{background:var(--fondo);border:1px solid var(--linea);border-radius:16px;padding:26px 28px;margin:40px 0;display:flex;flex-wrap:wrap;gap:16px;align-items:center;justify-content:space-between}
  .cta-inline p{font-family:'Montserrat';font-weight:700;color:var(--azul);font-size:17px}

  .faqs{margin-top:46px}
  .faqs h2{font-size:25px;font-weight:800;margin-bottom:18px}
  .faq{max-width:760px}
  details{background:#fff;border:1px solid var(--linea);border-radius:14px;margin-bottom:12px;overflow:hidden}
  summary{list-style:none;cursor:pointer;padding:18px 22px;font-family:'Montserrat';font-weight:600;font-size:16px;color:var(--azul);display:flex;justify-content:space-between;gap:14px;transition:transform .16s cubic-bezier(.23,1,.32,1),background .16s}
  summary:hover{background:#fafbfe}
  summary:active{transform:scale(.99)}
  summary::-webkit-details-marker{display:none}
  .plus{font-size:22px;color:var(--azul);transition:.2s;flex-shrink:0}
  details[open] .plus{transform:rotate(45deg)}
  .ans{padding:0 22px 18px;color:#555;font-size:15.5px}

  .relacionado{margin-top:46px;border-top:1px solid var(--linea);padding-top:26px}
  .rel-label{font-family:'Montserrat';font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--gris);margin-bottom:8px}
  .rel-link{font-family:'Montserrat';font-weight:700;font-size:19px;color:var(--azul);text-decoration:underline;text-underline-offset:3px}
  .rel-link:hover{color:var(--azul)}

  /* Sigue leyendo */
  .mas{padding:20px 0 76px}
  .mas .eyebrow{margin-bottom:10px}
  .mas h2{font-size:26px;font-weight:800;letter-spacing:-.3px;margin-bottom:28px}
  .mas .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:22px}
  .mas .card{position:relative;background:#fff;border:1px solid var(--linea);border-radius:16px;padding:24px;display:flex;flex-direction:column;transition:transform .18s,border-color .18s,box-shadow .18s;box-shadow:0 6px 18px -14px rgba(19,35,95,.4)}
  .mas .card:hover{transform:translateY(-3px);border-color:rgba(246,177,26,.65);box-shadow:0 22px 42px -20px rgba(19,35,95,.42)}
  .mas .card:active{transform:translateY(-3px) scale(.98)}
  .mas .card-tag{display:inline-block;font-family:'Montserrat';font-weight:700;font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--azul-prof);background:#fdf0d2;border-radius:20px;padding:4px 11px;margin-bottom:12px}
  .mas .card h3{font-size:18px;font-weight:800;line-height:1.3;margin-bottom:8px}
  .mas .card-lead{color:#555;font-size:14px;flex-grow:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .mas .card-meta{margin-top:16px;padding-top:14px;border-top:1px solid var(--linea);display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--gris);gap:10px}
  .mas .leer{font-family:'Montserrat';font-weight:700;color:var(--azul);font-size:13px;display:inline-flex;align-items:center;gap:5px;white-space:nowrap}
  .mas .leer svg{width:13px;height:13px;transition:transform .18s cubic-bezier(.23,1,.32,1)}
  .mas .card:hover .leer svg{transform:translateX(4px)}

  .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .cta-row.center{justify-content:center}
  .cierre{position:relative;background:linear-gradient(150deg,var(--azul),var(--azul-prof));color:#fff;text-align:center;padding:72px 24px;overflow:hidden}
  .cierre::before{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.05) 1px,transparent 1px);background-size:26px 26px;pointer-events:none}
  .cierre-eyebrow{position:relative;font-family:'Montserrat';font-weight:700;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--amarillo);margin-bottom:14px}
  .cierre h2{position:relative;color:#fff;font-size:28px;font-weight:800}
  .cierre p{position:relative;color:#cfd6ea;font-size:17px;margin:14px auto 26px;max-width:52ch}

  @media(max-width:640px){ .cab h1{font-size:28px} .prosa{font-size:16px} }
</style>
