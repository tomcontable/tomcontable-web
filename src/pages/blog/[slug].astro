---
import Base from '../../layouts/Base.astro';
import BotonWhatsApp from '../../components/BotonWhatsApp.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const d = post.data;

const url = `https://tomcontable.cl/blog/${post.slug}`;
const fmtFecha = (x) =>
  x.toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' });

// Tiempo de lectura estimado a partir del cuerpo
const palabras = post.body.trim().split(/\s+/).length;
const minutos = Math.max(1, Math.round(palabras / 200));

const seo = {
  title: d.seoTitle,
  description: d.description,
  canonical: `/blog/${post.slug}`,
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": d.title,
  "description": d.description,
  "datePublished": d.pubDate.toISOString(),
  "dateModified": (d.updatedDate ?? d.pubDate).toISOString(),
  "inLanguage": "es-CL",
  "mainEntityOfPage": url,
  "image": "https://tomcontable.cl/img/og-tomcontable.jpg",
  "author": {
    "@type": "Person",
    "@id": "https://tomcontable.cl/#tomas",
    "name": "Tomás Gómez Fuenzalida",
    "jobTitle": "Contador Colegiado",
    "url": "https://tomcontable.cl/sobre-tomcontable"
  },
  "publisher": {
    "@type": "Organization",
    "name": "TomContable",
    "logo": { "@type": "ImageObject", "url": "https://tomcontable.cl/img/logo-tomcontable.png" }
  }
};

const faqSchema = d.faqs.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": d.faqs.map((it) => ({
    "@type": "Question",
    "name": it.q,
    "acceptedAnswer": { "@type": "Answer", "text": it.a }
  }))
} : null;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://tomcontable.cl/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tomcontable.cl/blog/" },
    { "@type": "ListItem", "position": 3, "name": d.title, "item": url }
  ]
};

const schema = [articleSchema, breadcrumb, ...(faqSchema ? [faqSchema] : [])];
---
<Base {...seo} type="article" schema={schema}>

  <article>
    <header class="cab">
      <div class="wrap angosto">
        <p class="ruta"><a href="/blog/">Blog</a><span>/</span>{d.keyword}</p>
        <h1>{d.title}</h1>
        <p class="lead">{d.lead}</p>
        <p class="meta">Por Tom · {fmtFecha(d.pubDate)} · {minutos} min de lectura</p>
      </div>
    </header>

    <div class="cuerpo">
      <div class="wrap angosto">
        <div class="prosa">
          <Content />
        </div>

        <div class="cta-inline">
          <p>¿Quieres que veamos tu caso en concreto?</p>
          <BotonWhatsApp texto={d.ctaTexto} mensaje={d.ctaMensaje} />
        </div>

        {d.faqs.length > 0 && (
          <section class="faqs">
            <h2>Preguntas frecuentes</h2>
            <div class="faq">
              {d.faqs.map((it) => (
                <details>
                  <summary>{it.q}<span class="plus">+</span></summary>
                  <div class="ans">{it.a}</div>
                </details>
              ))}
            </div>
          </section>
        )}

        <aside class="relacionado">
          <p class="rel-label">Servicio relacionado</p>
          <a class="rel-link" href={d.servicioHref}>{d.servicioTexto}</a>
        </aside>
      </div>
    </div>
  </article>

  <section class="cierre">
    <div class="wrap">
      <h2>Más que contabilidad, tranquilidad.</h2>
      <p>Cuéntanos de tu empresa por WhatsApp y te orientamos en simple, sin compromiso.</p>
      <div class="cta-row center"><BotonWhatsApp texto={d.ctaTexto} mensaje={d.ctaMensaje} /></div>
    </div>
  </section>

</Base>

<style>
  .cab{background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%);padding:54px 0 44px}
  .angosto{max-width:760px}
  .ruta{font-family:'Montserrat';font-weight:600;font-size:13px;color:var(--gris);margin-bottom:16px;display:flex;gap:8px;align-items:center}
  .ruta a{color:var(--azul)}
  .ruta span{color:#c2c7d6}
  .cab h1{font-size:36px;font-weight:800;letter-spacing:-.5px;line-height:1.12}
  .cab .lead{font-size:18px;color:#444a63;margin:18px 0 18px}
  .meta{font-size:14px;color:var(--gris)}

  .cuerpo{padding:48px 0}

  /* Estilos del texto del articulo (markdown renderizado) */
  .prosa{font-size:17px;color:#33384a;line-height:1.75}
  .prosa :global(h2){font-size:25px;font-weight:800;margin:38px 0 14px;letter-spacing:-.3px}
  .prosa :global(h3){font-size:20px;font-weight:700;margin:28px 0 10px}
  .prosa :global(p){margin-bottom:18px}
  .prosa :global(ul),.prosa :global(ol){margin:0 0 18px 22px}
  .prosa :global(li){margin-bottom:8px}
  .prosa :global(a){color:var(--azul);font-weight:600;text-decoration:underline;text-underline-offset:2px}
  .prosa :global(a:hover){color:var(--azul-prof)}
  .prosa :global(strong){color:var(--azul)}

  .cta-inline{background:var(--fondo);border:1px solid var(--linea);border-radius:16px;padding:26px 28px;margin:40px 0;display:flex;flex-wrap:wrap;gap:16px;align-items:center;justify-content:space-between}
  .cta-inline p{font-family:'Montserrat';font-weight:700;color:var(--azul);font-size:17px}

  .faqs{margin-top:46px}
  .faqs h2{font-size:25px;font-weight:800;margin-bottom:18px}
  .faq{max-width:760px}
  details{background:#fff;border:1px solid var(--linea);border-radius:14px;margin-bottom:12px;overflow:hidden}
  summary{list-style:none;cursor:pointer;padding:18px 22px;font-family:'Montserrat';font-weight:600;font-size:16px;color:var(--azul);display:flex;justify-content:space-between;gap:14px}
  summary::-webkit-details-marker{display:none}
  .plus{font-size:22px;color:var(--azul);transition:.2s;flex-shrink:0}
  details[open] .plus{transform:rotate(45deg)}
  .ans{padding:0 22px 18px;color:#555;font-size:15.5px}

  .relacionado{margin-top:46px;border-top:1px solid var(--linea);padding-top:26px}
  .rel-label{font-family:'Montserrat';font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--gris);margin-bottom:8px}
  .rel-link{font-family:'Montserrat';font-weight:700;font-size:19px;color:var(--azul);text-decoration:underline;text-underline-offset:3px}
  .rel-link:hover{color:var(--azul)}

  .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .cta-row.center{justify-content:center}
  .cierre{background:linear-gradient(150deg,var(--azul),var(--azul-prof));color:#fff;text-align:center;padding:66px 24px}
  .cierre h2{color:#fff;font-size:28px;font-weight:800}
  .cierre p{color:#cfd6ea;font-size:17px;margin:14px auto 26px;max-width:52ch}

  @media(max-width:640px){ .cab h1{font-size:28px} .prosa{font-size:16px} }
</style>
