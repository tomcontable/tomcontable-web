---
import Base from '../layouts/Base.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';
import BannerServicios from '../components/BannerServicios.astro';

const seo = {
  title: 'Calculadora Boleta de Honorarios 2026 · TomContable',
  description: 'Pon el monto y mira al instante las dos simulaciones: cuánto recibes líquido si era el total, y por cuánto emitir si era tu líquido. Retención 15,25% (2026), en peso o UF. Gratis.',
  canonical: '/calculadora-boleta-honorarios',
};

const faqs = [
  { q: '¿Cuánto es la retención de la boleta de honorarios en 2026?', a: 'En 2026 la retención es 15,25% del monto bruto de la boleta. Sube de forma gradual cada año: fue 14,5% en 2025 y, según la ley, continúa subiendo a 16% en 2027 y 17% en 2028.' },
  { q: '¿Cuál es la diferencia entre el total, el bruto y el líquido?', a: 'El total y el bruto son lo mismo: el monto por el que emites la boleta, antes de la retención. El líquido es lo que te queda en el bolsillo después de descontar la retención. La gente suele confundir total y bruto, por eso esta calculadora te muestra los tres a la vez.' },
  { q: '¿Cómo se calcula el líquido de una boleta de honorarios?', a: 'Al monto bruto (o total) se le descuenta la retención (15,25% en 2026) y lo que queda es el líquido que recibes. Por ejemplo, una boleta de $1.000.000 en 2026 tiene una retención de $152.500, así que recibes $847.500.' },
  { q: '¿Por cuánto tengo que emitir para recibir un líquido determinado?', a: 'Divides el líquido que quieres recibir por uno menos la tasa de retención del año. En 2026, con retención de 15,25%, divides por 0,8475. La calculadora lo hace sola: si pones tu líquido objetivo, la segunda simulación te muestra el total a emitir.' },
  { q: '¿Puedo calcular la boleta en UF?', a: 'Sí. Puedes ingresar el monto en pesos o en UF. Si eliges UF, indicas la fecha y la calculadora toma el valor oficial de la UF de ese día para convertirlo a pesos antes de aplicar la retención.' },
  { q: '¿La retención es un impuesto que pierdo?', a: 'No. La retención es un adelanto de tus impuestos. En la operación renta del año siguiente se descuenta de lo que te toca pagar, y si retuvieron de más, te lo devuelven. Por eso conviene tenerla ordenada y no gastarla.' },
  { q: '¿Quién paga la retención, quien emite o quien recibe la boleta?', a: 'Depende de a quién le emitas. Si emites a una empresa, por lo general ella retiene y entera ese monto al SII. Si emites a una persona natural, normalmente te toca a ti declararlo y pagarlo en tu propia declaración de renta.' },
  { q: '¿Las boletas de honorarios pagan cotizaciones de AFP y salud?', a: 'Sí. Desde la reforma, los trabajadores a honorarios cotizan de forma obligatoria, y eso se financia con parte de la retención a través de la Operación Renta. Por eso la retención fue subiendo de forma gradual hasta llegar a 17% en 2028.' },
  { q: '¿Me conviene seguir a honorarios o crear una empresa?', a: 'Depende de cuánto facturas y de tus gastos. A medida que la retención sube y tus ingresos crecen, a varios independientes les empieza a convenir tener empresa propia. Conviene hacer el número antes de decidir; podemos revisar tu caso.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((it) => ({ '@type': 'Question', name: it.q, acceptedAnswer: { '@type': 'Answer', text: it.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Calculadora de Boleta de Honorarios', applicationCategory: 'FinanceApplication', operatingSystem: 'Web', inLanguage: 'es-CL', url: 'https://tomcontable.cl/calculadora-boleta-honorarios', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CLP' }, publisher: { '@type': 'Organization', name: 'TomContable' } };
const breadcrumb = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://tomcontable.cl/' },
  { '@type': 'ListItem', position: 2, name: 'Herramientas', item: 'https://tomcontable.cl/herramientas' },
  { '@type': 'ListItem', position: 3, name: 'Calculadora de boleta de honorarios', item: 'https://tomcontable.cl/calculadora-boleta-honorarios' }
] };

const actualizado = new Date().toLocaleDateString('es-CL', { month: 'long', year: 'numeric' });
---
<Base {...seo} schema={[appSchema, faqSchema, breadcrumb]} sugerencia="calculadora-boleta-honorarios">

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Herramienta gratis</p>
      <h1>Calculadora de boleta de honorarios 2026: retención y líquido</h1>
      <p class="lead">Pon el monto una vez y mira las dos simulaciones a la vez: cuánto te queda líquido si ese monto era el total, y por cuánto emitir si era tu líquido al bolsillo. En peso o en UF.</p>
    </div>
    <svg class="hero-ill" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M32 10h56v98l-9.3-6-9.3 6-9.4-6-9.3 6-9.4-6z" stroke="#1E2F73" stroke-width="3.5" stroke-linejoin="round"/><g stroke="#1E2F73" stroke-width="3" stroke-linecap="round"><path d="M44 32h32M44 46h32"/></g><circle cx="60" cy="78" r="15" fill="#F6B11A" fill-opacity="0.25"/><path d="M60 70v18M55 74h7a3 3 0 0 1 0 6h-5a3 3 0 0 0 0 6h7" stroke="#1E2F73" stroke-width="2.6" stroke-linecap="round"/></svg>
  </section>

  <section class="sec">
    <div class="wrap calc-wrap">

      <div class="grid">
        <form class="panel form" id="bh-form" autocomplete="off">
          <h2>Datos de la boleta</h2>
          <label class="f"><span id="monto-label">Monto</span>
            <div class="inp"><i id="monto-pre">$</i><input type="text" inputmode="decimal" id="monto" placeholder="0" /></div>
          </label>
          <div class="f2">
            <label class="f"><span>Moneda</span>
              <select id="moneda">
                <option value="peso">Peso</option>
                <option value="uf">UF</option>
              </select>
            </label>
            <label class="f"><span>Año de la boleta</span>
              <select id="anio">
                <option value="2025">2025 · retención 14,5%</option>
                <option value="2026" selected>2026 · retención 15,25%</option>
                <option value="2027">2027 · retención 16%</option>
                <option value="2028">2028 · retención 17%</option>
              </select>
            </label>
          </div>
          <label class="f" id="wrap-fecha"><span>Fecha de la UF</span>
            <input type="date" id="fecha" class="date" />
          </label>
          <p class="hint" id="hint-uf"></p>
        </form>

        <div class="result-col">
          <div class="panel comp" id="result">
            <div class="comp-head">
              <div class="comp-marca"><strong>TomContable</strong><span>tomcontable.cl</span></div>
              <span class="comp-tag">Boleta de honorarios</span>
            </div>
            <div class="comp-in"><span id="comp-in-label">Monto ingresado</span><b id="r-in">$0</b></div>
            <div class="sims">
              <div class="sim">
                <span class="sim-q">Si ese monto es el total <em>(bruto)</em></span>
                <span class="sim-k">Líquido al bolsillo</span>
                <strong class="sim-v" id="r-a-liq">$0</strong>
                <span class="sim-sub" id="r-a-ret">Retención 15,25%: $0</span>
              </div>
              <div class="sim">
                <span class="sim-q">Si ese monto es tu líquido al bolsillo</span>
                <span class="sim-k">Debes emitir por <em>(total / bruto)</em></span>
                <strong class="sim-v" id="r-b-bruto">$0</strong>
                <span class="sim-sub" id="r-b-ret">Retención 15,25%: $0</span>
              </div>
            </div>
            <p class="comp-pie">Estimación referencial · retención <span id="r-pct">15,25%</span> (Ley 21.133) · tomcontable.cl</p>
          </div>

          <div class="r-cta"><BotonWhatsApp texto="Quiero ordenar mis honorarios" mensaje="Hola vengo desde la calculadora de boleta de honorarios y quiero ayuda con mis impuestos a honorarios" /></div>
          <div class="r-mail">
            <button type="button" class="mail-toggle" id="mail-toggle">Recibir este cálculo en PDF a mi correo</button>
            <div class="mail-box" id="mail-box" hidden>
              <input class="inp-solo" id="mail-nombre" type="text" placeholder="Tu nombre" autocomplete="given-name" />
              <input class="inp-solo" type="email" id="mail-input" placeholder="tucorreo@ejemplo.cl" autocomplete="email" />
              <input class="hp" id="mail-website" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <label class="mail-check"><input type="checkbox" id="mail-consent" /><span>Acepto recibir mi cálculo en PDF y, cada cierto tiempo, contenido útil de TomContable. Puedo darme de baja cuando quiera. <a href="/privacidad/" target="_blank" rel="noopener">Política de privacidad</a>.</span></label>
              <button type="button" class="btn btn-amber" id="mail-send">Enviarme el PDF</button>
              <p class="mail-msg" id="mail-msg" role="status"></p>
            </div>
          </div>
        </div>
      </div>

      <div class="descargo">
        <p>Cálculo referencial generado en tomcontable.cl con el monto ingresado. No constituye boleta oficial, comprobante ni asesoría tributaria. La retención depende del año de emisión y de tu situación; tu impuesto final se determina en la Operación Renta. Si calculas en UF, se usa el valor oficial de la UF de la fecha que elijas.</p>
        <p class="firma">TomContable.cl · Cálculo referencial</p>
      </div>
    </div>
  </section>

  <div style="margin:10px auto 56px;padding:0 20px"><BannerServicios orden={['constitucion', 'asesorias', 'proyeccion', 'contabilidad']} lateral={true} /></div>

  <section class="sec-texto">
    <div class="wrap angosto">
      <div class="resp-rapida">
        <p><strong>Respuesta rápida:</strong> esta calculadora de boleta de honorarios muestra, con un solo monto, las dos simulaciones que la gente confunde: cuánto recibes líquido si ese monto era el total o bruto, y por cuánto debes emitir si era tu líquido al bolsillo. Usa la retención vigente en Chile (15,25% en 2026) y permite calcular en peso o en UF. El resultado es referencial.</p>
        <p class="resp-fecha">Última actualización: {actualizado}. Fuente: tasa de retención vigente (Ley 21.133), 15,25% en 2026.</p>
      </div>

      <h2>Total, bruto y líquido: la confusión de siempre</h2>
      <p>El total y el bruto de una boleta son lo mismo: el monto por el que emites, antes de descontar la retención. El líquido es lo que realmente te llega al bolsillo, ya con la retención descontada. Como casi todos mezclan estas palabras, esta calculadora no te obliga a elegir: pones un solo monto y te muestra las dos lecturas posibles a la vez, así no hay forma de equivocarse.</p>

      <h2>Qué es la retención de la boleta de honorarios</h2>
      <p>Al emitir una boleta de honorarios se aplica una retención, que en 2026 es del 15,25% del monto bruto. Esa retención no es plata que pierdes: es un anticipo a cuenta de tus impuestos del año, que se ajusta en la Operación Renta de abril. La tasa sube de forma gradual: fue 14,5% en 2025 y llega a 17% en 2028.</p>

      <h2>Cómo se calcula el líquido de una boleta</h2>
      <p>Al monto bruto se le descuenta la retención del año y lo que queda es el líquido. Por ejemplo, una boleta de $1.000.000 en 2026 tiene una retención de $152.500, así que recibes $847.500. Esa es la primera simulación que ves: si el monto que pusiste era el total, ese es tu líquido al bolsillo.</p>

      <h2>Por cuánto emitir para recibir un líquido objetivo</h2>
      <p>La segunda simulación va al revés. Si lo que pusiste era el líquido que quieres recibir, te dice por cuánto emitir la boleta para llegar a esa cifra, ya considerando la retención. Es justo lo que necesitas cuando acuerdas un pago neto con un cliente: en 2026, para recibir $1.000.000 líquidos, debes emitir por $1.180.638.</p>

      <h2>Calcular la boleta en UF</h2>
      <p>Si tu servicio está pactado en UF, puedes ingresar el monto en UF y elegir la fecha. La calculadora toma el valor oficial de la UF de ese día, lo convierte a pesos y recién ahí aplica la retención, porque la boleta y la retención siempre se expresan en pesos. Así ves el equivalente exacto sin tener que hacer la conversión a mano.</p>

      <h2>Quién paga la retención: tú o la empresa</h2>
      <p>Depende de a quién le emitas. Si le emites a una empresa, por lo general ella retiene el porcentaje y lo entera al SII a tu nombre, y te paga el líquido. Si le emites a una persona natural, normalmente el pago te llega completo y la retención la declaras y pagas tú en tu propia renta. En el año, el total retenido es el mismo.</p>

      <h2>La retención y la Operación Renta</h2>
      <p>En abril, en la Operación Renta, se suma todo lo que boleteaste en el año y se calcula tu impuesto real. La retención que te hicieron se descuenta de ahí. Si retuvieron de más, te devuelven; si tus ingresos fueron altos y la retención no alcanzó, te puede tocar pagar. Además, una parte de la retención financia tus cotizaciones obligatorias como trabajador independiente. Por eso conviene proyectar con tiempo y no gastarse la retención.</p>

      <h2>¿Te conviene seguir a honorarios o crear una empresa?</h2>
      <p>Mientras la retención sigue subiendo año a año, a muchos independientes con ingresos que crecen les empieza a convenir facturar con empresa propia en vez de a honorarios. No es para todos, pero vale la pena hacer el número. Si quieres ver tu caso lo conversamos, y si decides dar el paso te dejamos la <a href="/constitucion-de-empresas/">empresa constituida y lista para facturar</a>.</p>

      <h2 id="faq">Preguntas frecuentes</h2>
      <div class="faq">
        {faqs.map((it) => (
          <details>
            <summary>{it.q}<span class="plus">+</span></summary>
            <div class="ans">{it.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="relac">
    <div class="relac-in">
      <h2>Herramientas relacionadas</h2>
      <div class="relac-grid">
        <a href="/calculadora-iva/">Calculadora de IVA</a>
        <a href="/calculadora-uf/">Calculadora UF a pesos</a>
        <a href="/constitucion-de-empresas/">Constituir una empresa</a>
        <a href="/proyeccion-tributaria/">Proyección tributaria</a>
      </div>
    </div>
  </section>

  <section class="cierre">
    <div class="wrap">
      <h2>¿Trabajas a honorarios y no quieres sustos en abril?</h2>
      <p>Te ayudamos a proyectar tus impuestos y a llegar ordenado a la Operación Renta. Conversemos por WhatsApp.</p>
      <div class="cta-row center"><BotonWhatsApp texto="Hablar por WhatsApp" mensaje="Hola vengo desde la calculadora de boleta de honorarios" /></div>
    </div>
  </section>

</Base>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
  // Retención de boletas de honorarios por año (Ley 21.133, sube gradual hasta 17% en 2028).
  const RET = { 2025: 0.145, 2026: 0.1525, 2027: 0.16, 2028: 0.17 };

  const fmt0 = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
  const fmtUF = (n) => n.toLocaleString('es-CL', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const $ = (id) => document.getElementById(id);
  const num = (id) => { const v = $(id).value; if (!v) return 0; const n = parseFloat(String(v).replace(/\./g, '').replace(/,/g, '.').replace(/[^\d.]/g, '')); return isFinite(n) ? n : 0; };
  const pctTxt = (r) => { let s = (r * 100).toFixed(2).replace(/0+$/, '').replace(/\.$/, ''); return s.replace('.', ',') + '%'; };

  const monedaEl = $('moneda'), anioEl = $('anio'), fechaEl = $('fecha');
  const ufCache = {};

  const fmtLarga = (iso) => { const [y, m, d] = iso.split('-').map(Number); return new Date(y, m - 1, d).toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' }); };

  // Valor oficial de la UF para una fecha (mindicador / Banco Central). Si no hay dato ese día, usa el vigente anterior.
  const ufParaFecha = async (fechaStr) => {
    let anio = parseInt(fechaStr.slice(0, 4), 10);
    for (let intento = 0; intento < 2; intento++) {
      if (!ufCache[anio]) {
        try {
          const data = await fetch(`https://mindicador.cl/api/uf/${anio}`).then((r) => r.json());
          const map = {}, arr = [];
          (data.serie || []).forEach((it) => { const f = it.fecha.slice(0, 10); map[f] = it.valor; arr.push({ fecha: f, valor: it.valor }); });
          arr.sort((a, b) => (a.fecha < b.fecha ? 1 : -1));
          ufCache[anio] = { map, arr };
        } catch (e) { return null; }
      }
      const { map, arr } = ufCache[anio];
      if (map[fechaStr]) return { valor: map[fechaStr], fecha: fechaStr };
      const prev = arr.find((it) => it.fecha <= fechaStr);
      if (prev) return { valor: prev.valor, fecha: prev.fecha };
      anio -= 1; fechaStr = `${anio}-12-31`;
    }
    return null;
  };

  const zero = () => { ['r-in', 'r-a-liq', 'r-b-bruto'].forEach((id) => $(id).textContent = '$0'); $('r-a-ret').textContent = ''; $('r-b-ret').textContent = ''; };

  const calcular = async () => {
    const moneda = monedaEl.value;
    const r = RET[anioEl.value] || 0.1525;
    const monto = num('monto');
    $('r-pct').textContent = pctTxt(r);

    let montoPesos = monto, detalleUF = '';
    if (moneda === 'uf') {
      if (monto > 0) {
        const res = await ufParaFecha(fechaEl.value);
        if (res) { montoPesos = Math.round(monto * res.valor); detalleUF = `${fmtUF(monto)} UF al ${fmtLarga(res.fecha)}`; }
        else { $('hint-uf').textContent = 'No pudimos obtener la UF de esa fecha. Prueba con otra o usa pesos.'; zero(); return; }
      } else { montoPesos = 0; }
      $('hint-uf').textContent = 'Tomamos el valor oficial de la UF del día que elijas. Usa coma para los decimales, por ejemplo 2,5 UF.';
    }

    if (montoPesos <= 0) { zero(); $('comp-in-label').textContent = 'Monto ingresado'; $('r-in').textContent = '$0'; return; }

    $('comp-in-label').textContent = detalleUF ? `Monto ingresado · ${detalleUF}` : 'Monto ingresado';
    $('r-in').textContent = fmt0.format(montoPesos);

    // A: el monto es el total (bruto) -> líquido al bolsillo
    const liqA = Math.round(montoPesos * (1 - r));
    const retA = montoPesos - liqA;
    // B: el monto es el líquido -> total/bruto a emitir
    const brutoB = Math.round(montoPesos / (1 - r));
    const retB = brutoB - montoPesos;

    $('r-a-liq').textContent = fmt0.format(liqA);
    $('r-a-ret').textContent = `Retención ${pctTxt(r)}: ${fmt0.format(retA)}`;
    $('r-b-bruto').textContent = fmt0.format(brutoB);
    $('r-b-ret').textContent = `Retención ${pctTxt(r)}: ${fmt0.format(retB)}`;
  };

  const toggleMoneda = () => {
    const esUF = monedaEl.value === 'uf';
    $('wrap-fecha').style.display = esUF ? 'block' : 'none';
    $('monto-pre').textContent = esUF ? 'UF' : '$';
    $('monto-label').textContent = esUF ? 'Monto en UF' : 'Monto en pesos';
    if (!esUF) $('hint-uf').textContent = '';
  };

  monedaEl.addEventListener('change', () => { toggleMoneda(); calcular(); });
  $('bh-form').addEventListener('input', calcular);
  $('bh-form').addEventListener('change', calcular);

  // Fecha por defecto: hoy
  const today = new Date();
  const pad = (n) => String(n).padStart(2, '0');
  fechaEl.value = `${today.getFullYear()}-${pad(today.getMonth() + 1)}-${pad(today.getDate())}`;
  toggleMoneda();
  calcular();

  // PDF imprimible + envío por correo (captura de lead)
  let logoImg = null;
  (() => { const im = new Image(); im.crossOrigin = 'anonymous'; im.onload = () => { logoImg = im; }; im.src = '/img/logo-tomcontable.png'; })();

  const buildPDFBase64 = () => {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'mm', format: 'a4' });
    const W = 210, M = 18;
    if (doc.setGState) doc.setGState(new doc.GState({ opacity: 0.09 }));
    doc.setTextColor(19, 35, 95); doc.setFont('helvetica', 'bold'); doc.setFontSize(15);
    let wr = 0; for (let yy = 55; yy < 290; yy += 54) { let wc = 0; for (let xx = -5; xx < 215; xx += 94) { doc.text((wr + wc) % 2 === 0 ? 'Cálculo referencial' : 'tomcontable.cl', xx, yy, { angle: 30 }); wc++; } wr++; }
    if (doc.setGState) doc.setGState(new doc.GState({ opacity: 1 }));
    if (logoImg) { try { const lw = 42; const ratio = (logoImg.naturalHeight && logoImg.naturalWidth) ? (logoImg.naturalHeight / logoImg.naturalWidth) : 0.26; doc.addImage(logoImg, 'PNG', M, 13, lw, lw * ratio); } catch (e) {} }
    doc.setTextColor(30, 47, 115); doc.setFont('helvetica', 'bold'); doc.setFontSize(18);
    doc.text('Boleta de honorarios', M, 38);
    doc.setFont('helvetica', 'normal'); doc.setFontSize(9); doc.setTextColor(139, 147, 179);
    doc.text('Generada el ' + new Date().toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' }), M, 44);

    doc.setFont('helvetica', 'normal'); doc.setFontSize(11); doc.setTextColor(51, 56, 74);
    doc.text(($('comp-in-label').textContent || 'Monto ingresado') + ':', M, 56);
    doc.setFont('helvetica', 'bold'); doc.setTextColor(19, 35, 95);
    doc.text($('r-in').textContent, W - M, 56, { align: 'right' });

    const box = (y, q, k, v, sub) => {
      doc.setFillColor(30, 47, 115); doc.roundedRect(M, y, W - 2 * M, 26, 2, 2, 'F');
      doc.setTextColor(207, 214, 234); doc.setFont('helvetica', 'normal'); doc.setFontSize(9.5);
      doc.text(q, M + 5, y + 7);
      doc.setTextColor(159, 176, 216); doc.setFontSize(8.5);
      doc.text(k, M + 5, y + 13.5);
      doc.setTextColor(246, 177, 26); doc.setFont('helvetica', 'bold'); doc.setFontSize(16);
      doc.text(v, W - M - 5, y + 13, { align: 'right' });
      doc.setTextColor(207, 214, 234); doc.setFont('helvetica', 'normal'); doc.setFontSize(8.5);
      doc.text(sub, M + 5, y + 21);
    };
    box(64, 'Si ese monto es el total (bruto)', 'Liquido al bolsillo', $('r-a-liq').textContent, ($('r-a-ret').textContent || '').replace(/−/g, '-'));
    box(95, 'Si ese monto es tu liquido al bolsillo', 'Debes emitir por (total / bruto)', $('r-b-bruto').textContent, ($('r-b-ret').textContent || '').replace(/−/g, '-'));

    let y = 132;
    const disc = 'Cálculo referencial generado en tomcontable.cl con el monto ingresado. No constituye boleta oficial, comprobante ni asesoría tributaria. La retención depende del año de emisión y de tu situación; tu impuesto final se determina en la Operación Renta.';
    doc.setFont('helvetica', 'normal'); doc.setFontSize(8); doc.setTextColor(120, 120, 130);
    doc.text(doc.splitTextToSize(disc, W - 2 * M), M, y);
    doc.setTextColor(139, 147, 179); doc.setFontSize(8.5);
    doc.text('TomContable · Más que contabilidad, tranquilidad · tomcontable.cl · WhatsApp +56 9 3650 6297', M, 290);
    return doc.output('datauristring').split(',')[1];
  };

  $('mail-toggle').addEventListener('click', () => { const box = $('mail-box'); box.hidden = !box.hidden; if (!box.hidden) $('mail-nombre').focus(); });
  $('mail-send').addEventListener('click', async () => {
    const msg = $('mail-msg'); const btn = $('mail-send');
    if (btn.disabled) return;
    const email = $('mail-input').value.trim();
    const nombre = $('mail-nombre').value.trim();
    const consent = $('mail-consent').checked;
    const website = $('mail-website').value;
    msg.className = 'mail-msg';
    if ($('r-a-liq').textContent === '$0') { msg.textContent = 'Primero completa el cálculo arriba.'; return; }
    if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { msg.textContent = 'Revisa tu correo, no parece válido.'; return; }
    if (!consent) { msg.textContent = 'Marca la casilla para poder enviarte el PDF.'; return; }
    btn.disabled = true; const btnTxt = btn.textContent; btn.textContent = 'Enviando…'; msg.textContent = 'Generando tu PDF y enviándolo…';
    await new Promise((r) => setTimeout(r, 40));
    let pdf = ''; try { if (window.jspdf) pdf = buildPDFBase64(); } catch (e) { pdf = ''; }
    try {
      const resp = await fetch('/api/enviar-calculo', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ tipo: 'boleta', email, nombre, consent, website, pdf }) });
      const j = await resp.json();
      if (j && j.ok) { msg.className = 'mail-msg ok'; msg.textContent = '¡Listo! Te enviamos el PDF a ' + email + '. Revisa tu bandeja de entrada (y la carpeta de spam).'; }
      else { msg.textContent = 'No pudimos enviarlo ahora. Inténtalo en un rato.'; }
    } catch (e) { msg.textContent = 'No pudimos enviarlo ahora. Inténtalo en un rato.'; }
    btn.disabled = false; btn.textContent = btnTxt;
  });
</script>

