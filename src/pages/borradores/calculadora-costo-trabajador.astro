---
import Base from '../../layouts/Base.astro';
import BotonWhatsApp from '../../components/BotonWhatsApp.astro';

const seo = {
  title: 'Calculadora de Sueldo Líquido y Costo de Contratación | TomContable',
  description: 'Calcula el sueldo líquido del trabajador y el costo total para la empresa. Desde el sueldo base o el líquido deseado. Gratis, con datos previsionales actualizados.',
  canonical: '/borradores/calculadora-costo-trabajador',
  noindex: true,
};

const jornadas = Array.from({ length: 41 }, (_, i) => 42 - i); // 42 .. 2
const diasMes = Array.from({ length: 30 }, (_, i) => 30 - i);  // 30 .. 1 (tope legal 30)
---
<Base {...seo}>

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Herramienta gratis</p>
      <h1>Calculadora de sueldo líquido y costo de contratación</h1>
      <p class="lead">Ingresa el sueldo base (o el líquido que quieres pagar) y verás el líquido del trabajador y el costo total para tu empresa, desglosado.</p>
    </div>
  </section>

  <section class="sec">
    <div class="wrap calc-wrap">
      <p class="aviso-top"><strong>BORRADOR: pendiente de validación.</strong> Los indicadores (sueldo mínimo, topes, tasas AFP, AFC, SIS, expectativa de vida) se cargan automáticamente desde Previred. Falta validar la lógica completa antes de dar de alta. Ver "Parámetros usados" abajo.</p>

      <div class="grid">
        <form class="panel form" id="cw-form" autocomplete="off">
          <h2>Datos del sueldo</h2>

          <div class="f2">
            <label class="f"><span>Calcular a partir de</span>
              <select id="modo"><option value="base">Sueldo base</option><option value="liquido">Sueldo líquido deseado</option></select>
            </label>
            <label class="f"><span id="monto-label">Sueldo base mensual</span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="monto" placeholder="0" /></div></label>
          </div>

          <div class="f2">
            <label class="f"><span>Gratificación legal</span><select id="grat"><option value="si">Sí (25% con tope)</option><option value="no">No</option></select></label>
            <label class="f"><span>AFP</span><select id="afp"></select></label>
          </div>

          <div class="f2">
            <label class="f"><span>Salud</span><select id="salud-tipo"><option value="fonasa">Fonasa (7%)</option><option value="isapre">Isapre (plan en UF)</option></select></label>
            <label class="f"><span>Tipo de contrato</span><select id="tipo"><option value="indef">Indefinido</option><option value="plazo">Plazo fijo / por obra</option></select></label>
          </div>

          <label class="f" id="isapre-wrap" hidden><span>Valor del plan de Isapre <em>(en UF, mensual)</em></span><div class="inp"><input type="text" inputmode="decimal" id="isapre-uf" placeholder="0" /><i>UF</i></div></label>

          <div class="f2">
            <label class="f"><span>Jornada semanal</span><select id="jornada">{jornadas.map((h) => (<option value={h} selected={h === 42}>{h} hrs</option>))}</select></label>
            <label class="f"><span>Días trabajados <em>(en el mes)</em></span><select id="dias">{diasMes.map((d) => (<option value={d} selected={d === 30}>{d}</option>))}</select></label>
          </div>

          <details class="more" id="more">
            <summary>Agregar más detalle <span class="plus">+</span></summary>
            <div class="more-body">
              <div class="f2">
                <label class="f"><span>Bonos</span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="bonos" placeholder="0" /></div></label>
                <label class="f"><span>El bono es</span><select id="bono-tipo"><option value="bruto">Bruto (imponible)</option><option value="liquido">Líquido</option></select></label>
              </div>
              <div class="f2">
                <label class="f"><span>Otras asignaciones <em>(no imponible)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="asig" placeholder="0" /></div></label>
                <label class="f"><span>Colación <em>(no imponible)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="colacion" placeholder="0" /></div></label>
              </div>
              <div class="f2">
                <label class="f"><span>Movilización <em>(no imponible)</em></span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="moviliz" placeholder="0" /></div></label>
                <label class="f"><span>Tasa de mutual <em>(%)</em></span><div class="inp"><input type="text" inputmode="decimal" id="mutual" placeholder="0,93" /><i>%</i></div></label>
              </div>
              <div class="f2">
                <label class="f"><span>Horas extra <em>(N°)</em></span><input type="text" inputmode="decimal" id="hextra" placeholder="0" /></label>
                <label class="f"><span>Horas de atraso <em>(N°)</em></span><input type="text" inputmode="decimal" id="hatraso" placeholder="0" /></label>
              </div>
              <label class="f"><span>Anticipos y otros descuentos</span><div class="inp"><i>$</i><input type="text" inputmode="numeric" id="descuentos" placeholder="0" /></div></label>
            </div>
          </details>
        </form>

        <div class="panel result" id="result">
          <div class="dual">
            <div class="dual-box"><span>Líquido del trabajador</span><strong id="r-liquido">$0</strong></div>
            <div class="dual-box alt"><span>Costo total para la empresa</span><strong id="r-costo">$0</strong></div>
          </div>
          <p class="aviso-min" id="aviso-min" hidden></p>
          <p class="r-sub">Haberes</p>
          <div class="r-rows" id="r-haberes"></div>
          <p class="r-sub">Descuentos del trabajador</p>
          <div class="r-rows" id="r-desc"></div>
          <p class="r-sub">Costos del empleador</p>
          <div class="r-rows" id="r-emp"></div>
          <p class="r-meta" id="r-meta"></p>
          <div class="r-cta"><BotonWhatsApp texto="Quiero ayuda con mis remuneraciones" mensaje="Hola vengo desde la calculadora de sueldo y quiero ayuda con remuneraciones" /></div>
        </div>
      </div>

      <details class="params">
        <summary>Parámetros usados (verifícalos antes de publicar)<span class="plus">+</span></summary>
        <div id="params-body" class="params-body"></div>
      </details>
    </div>
  </section>

  <section class="cierre">
    <div class="wrap">
      <h2>¿Necesitas llevar las remuneraciones de tu pyme bien hechas?</h2>
      <p>Calculamos liquidaciones, cotizaciones y todo lo laboral por ti. Conversemos por WhatsApp.</p>
      <div class="cta-row center"><BotonWhatsApp texto="Hablar por WhatsApp" mensaje="Hola vengo desde la calculadora de sueldo" /></div>
    </div>
  </section>

</Base>

<script>
  // Indicadores de respaldo (Previred mayo 2026). Si /api/indicadores-previred responde,
  // se reemplazan por los del mes. La mutual y el impuesto único no vienen de Previred.
  const FALLBACK = {
    fuente: 'respaldo', periodo: 'mayo 2026', sueldoMinimo: 539000,
    topeAFP_UF: 90, topeAFC_UF: 135.2, sis: 0.0162,
    afcEmpleadorIndef: 0.024, afcTrabajadorIndef: 0.006, afcEmpleadorPlazo: 0.030,
    cargoEmpleadorAFP: 0.001, expectativaVida: 0.009,
    afps: { Capital: 0.1144, Cuprum: 0.1144, Habitat: 0.1127, PlanVital: 0.1116, ProVida: 0.1145, Modelo: 0.1058, Uno: 0.1046 },
  };
  const JORNADA_COMPLETA = 42; // jornada ordinaria legal vigente (Ley 40 horas, 42 hrs desde 2026)
  // Impuesto único 2ª categoría mensual, tramos en UTM: [hasta, factor, rebaja UTM]
  const TRAMOS = [[13.5,0,0],[30,0.04,0.54],[50,0.08,1.74],[70,0.135,4.49],[90,0.23,11.14],[120,0.304,17.8],[310,0.35,23.32],[Infinity,0.40,38.82]];
  let D = FALLBACK;
  let UF = 40763, UTM = 71506;

  const fmt0 = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
  const $ = (id) => document.getElementById(id);
  const num = (id) => { const v = $(id).value; if (!v) return 0; const n = parseFloat(String(v).replace(/\./g,'').replace(/,/g,'.').replace(/[^\d.]/g,'')); return isFinite(n) ? n : 0; };
  const dec = (id) => { const v = $(id).value; if (!v) return 0; const n = parseFloat(String(v).replace(/[^\d.,]/g,'').replace(',','.')); return isFinite(n) ? n : 0; };
  const pct = (x) => (x * 100).toFixed(2).replace('.', ',');

  const rowsHtml = (arr) => arr.filter((f) => f).map((f) => `<div class="rr"><span class="rr-c">${f[0]}</span><span class="rr-v${f[2] ? ' neg' : ''}">${(f[2] ? '-' : '') + fmt0.format(Math.round(f[1]))}</span></div>`).join('');

  const llenarAFPs = () => {
    const sel = $('afp'); const prev = sel.value;
    sel.innerHTML = Object.keys(D.afps).map((k) => `<option value="${k}">${k} (${(D.afps[k]*100).toFixed(2).replace('.', ',')}%)</option>`).join('');
    if (prev && D.afps[prev]) sel.value = prev; else if (D.afps.Modelo) sel.value = 'Modelo';
  };

  // Liquidación completa a partir del sueldo base mensual contractual.
  const liquidar = (base, P) => {
    const baseEarned = base * (P.dias / 30);                 // proporcional a los días trabajados
    const grat = P.gratOn ? Math.min(baseEarned * 0.25, P.topeGrat) : 0;
    const valHoraExtra = base * 0.35 / P.jornada;            // hora con recargo 50% (sobre sueldo mensual)
    const valHoraOrd = base * 7 / (30 * P.jornada);          // hora ordinaria (para atrasos)
    const hExtra = P.hExtraN * valHoraExtra;                 // imponible
    const atraso = P.hAtrasoN * valHoraOrd;                  // rebaja la base imponible

    const imponible = Math.max(0, baseEarned + grat + P.bonos + hExtra - atraso);
    const impCap = Math.min(imponible, D.topeAFP_UF * UF);
    const impAFC = Math.min(imponible, D.topeAFC_UF * UF);

    const afp = impCap * P.afpTasa;
    const saludLegal = impCap * 0.07;                                            // 7% obligatorio
    const adicIsapre = P.isapre ? Math.max(0, P.isapreUF * UF - saludLegal) : 0; // diferencia sobre el 7%
    const afcTrab = P.indef ? impAFC * D.afcTrabajadorIndef : 0;

    // El impuesto deduce las cotizaciones legales (AFP, 7% salud, cesantía); el adicional de Isapre no.
    const baseTrib = imponible - (afp + saludLegal + afcTrab);
    const tUTM = baseTrib / UTM;
    let factor = 0, rebaja = 0;
    for (const [hasta, f, r] of TRAMOS) { if (tUTM <= hasta) { factor = f; rebaja = r; break; } }
    const impuesto = Math.max(0, tUTM * factor - rebaja) * UTM;

    const noImp = P.colacion + P.moviliz + P.asig;
    const liquido = imponible + noImp - afp - saludLegal - adicIsapre - afcTrab - impuesto - P.anticipos;

    const afcEmp = P.indef ? impAFC * D.afcEmpleadorIndef : impAFC * D.afcEmpleadorPlazo;
    const sis = impCap * D.sis;
    const mut = impCap * P.mutualTasa;
    const capInd = impCap * D.cargoEmpleadorAFP;   // capitalización individual (0,1%)
    const expVida = impCap * D.expectativaVida;    // expectativa de vida (0,9%)
    const costo = imponible + noImp + afcEmp + sis + mut + capInd + expVida;

    return { baseEarned, grat, bonos: P.bonos, hExtra, atraso, colacion: P.colacion, moviliz: P.moviliz, asig: P.asig,
      afp, saludLegal, adicIsapre, afcTrab, impuesto, factor, anticipos: P.anticipos,
      afcEmp, sis, mut, capInd, expVida, liquido, costo };
  };

  const vaciar = () => { $('r-liquido').textContent = '$0'; $('r-costo').textContent = '$0'; $('aviso-min').hidden = true; $('r-haberes').innerHTML = '<p class="rr-empty">Ingresa el monto.</p>'; $('r-desc').innerHTML = ''; $('r-emp').innerHTML = ''; $('r-meta').textContent = ''; };

  const calcular = () => {
    const modo = $('modo').value;
    const afpKey = $('afp').value;
    const saludTipo = $('salud-tipo').value;
    const jornada = parseInt($('jornada').value, 10) || JORNADA_COMPLETA;
    const jornadaParcial = jornada < JORNADA_COMPLETA;
    const dias = Math.min(30, parseInt($('dias').value, 10) || 30);
    const bonoTipo = $('bono-tipo').value;
    const rawBono = num('bonos');

    const P = {
      gratOn: $('grat').value === 'si',
      topeGrat: (4.75 * D.sueldoMinimo) / 12,
      indef: $('tipo').value === 'indef',
      afpTasa: D.afps[afpKey] || 0.1144,
      isapre: saludTipo === 'isapre',
      isapreUF: dec('isapre-uf'),
      jornada, dias,
      hExtraN: dec('hextra'),
      hAtrasoN: dec('hatraso'),
      bonos: rawBono,
      mutualTasa: (dec('mutual') || 0.93) / 100,
      asig: num('asig'),
      colacion: num('colacion'),
      moviliz: num('moviliz'),
      anticipos: num('descuentos'),
    };

    const monto = num('monto');
    if (monto <= 0) { vaciar(); return; }

    const solveBase = (Pp) => { let lo = 0, hi = Math.max(monto * 3, 1000000); for (let i = 0; i < 60; i++) { const mid = (lo + hi) / 2; if (liquidar(mid, Pp).liquido < monto) lo = mid; else hi = mid; } return (lo + hi) / 2; };

    let base = (modo === 'liquido') ? solveBase(P) : monto;

    // Embrutecer el bono si se ingresó como líquido (lo que el trabajador recibe en mano por ese bono)
    if (bonoTipo === 'liquido' && rawBono > 0) {
      const prelim = liquidar(base, { ...P, bonos: 0 });
      const keep = 1 - P.afpTasa - 0.07 - (P.indef ? D.afcTrabajadorIndef : 0) - prelim.factor;
      P.bonos = keep > 0.05 ? rawBono / keep : rawBono;
      if (modo === 'liquido') base = solveBase(P);
    }

    const r = liquidar(base, P);
    $('r-liquido').textContent = fmt0.format(Math.round(r.liquido));
    $('r-costo').textContent = fmt0.format(Math.round(r.costo));

    // Aviso: sueldo base bajo el mínimo legal (proporcional si la jornada es parcial)
    const minProp = jornadaParcial ? D.sueldoMinimo * (jornada / JORNADA_COMPLETA) : D.sueldoMinimo;
    const avisoEl = $('aviso-min');
    if (base > 0 && base < minProp - 1) {
      avisoEl.hidden = false;
      avisoEl.textContent = jornadaParcial
        ? `Atención: el sueldo base está bajo el mínimo proporcional de esta jornada (${fmt0.format(Math.round(minProp))} para ${jornada} hrs). Revisa que cumpla el ingreso mínimo legal.`
        : `Atención: el sueldo base está bajo el ingreso mínimo legal (${fmt0.format(Math.round(minProp))}).`;
    } else {
      avisoEl.hidden = true;
    }

    $('r-haberes').innerHTML = rowsHtml([
      ['Sueldo base' + (dias < 30 ? ` (${dias} días)` : ''), r.baseEarned, false],
      P.gratOn && ['Gratificación legal', r.grat, false],
      P.bonos > 0 && [bonoTipo === 'liquido' ? 'Bonos (imponible, embrutecido)' : 'Bonos (imponible)', P.bonos, false],
      r.hExtra > 0 && ['Horas extra', r.hExtra, false],
      r.atraso > 0 && ['Descuento por atrasos', r.atraso, true],
      r.colacion > 0 && ['Colación', r.colacion, false],
      r.moviliz > 0 && ['Movilización', r.moviliz, false],
      r.asig > 0 && ['Otras asignaciones', r.asig, false],
    ]);
    $('r-desc').innerHTML = rowsHtml([
      ['AFP (' + afpKey + ')', r.afp, true],
      ['Salud obligatoria (7%)', r.saludLegal, true],
      r.adicIsapre > 0 && ['Adicional Isapre', r.adicIsapre, true],
      P.indef && ['Seguro de cesantía', r.afcTrab, true],
      r.impuesto > 0 && ['Impuesto único', r.impuesto, true],
      r.anticipos > 0 && ['Anticipos y otros descuentos', r.anticipos, true],
    ]);
    $('r-emp').innerHTML = rowsHtml([
      ['Seguro de cesantía (empleador)', r.afcEmp, false],
      ['SIS', r.sis, false],
      ['Mutual (' + pct(P.mutualTasa) + '%)', r.mut, false],
      ['Capitalización individual (' + pct(D.cargoEmpleadorAFP) + '%)', r.capInd, false],
      ['Expectativa de vida (' + pct(D.expectativaVida) + '%)', r.expVida, false],
    ]);

    const fuenteTxt = D.fuente === 'previred' ? 'Indicadores Previred (' + D.periodo + ')' : 'Valores de respaldo, verificar';
    const sueldoBaseTxt = modo === 'liquido' ? ' · Sueldo base estimado: ' + fmt0.format(Math.round(base)) : '';
    $('r-meta').textContent = `${fuenteTxt} · UF ${fmt0.format(Math.round(UF))} · UTM ${fmt0.format(Math.round(UTM))}${sueldoBaseTxt}.`;
  };

  const pintarParams = () => {
    const origen = D.fuente === 'previred' ? `cargados automáticamente desde <strong>Previred (${D.periodo})</strong>` : `<strong>valores de respaldo</strong> (Previred no respondió)`;
    $('params-body').innerHTML = `<ul>
      <li>Origen de los datos: ${origen}.</li>
      <li>Sueldo mínimo: <strong>${fmt0.format(D.sueldoMinimo)}</strong> · Tope imponible AFP/salud: <strong>${D.topeAFP_UF} UF</strong> · Tope cesantía: <strong>${D.topeAFC_UF} UF</strong></li>
      <li>AFP (cargo trabajador, incluye 10% + comisión): ${Object.keys(D.afps).map((k) => `${k} ${pct(D.afps[k])}%`).join(' · ')}</li>
      <li>Salud: Fonasa 7% o Isapre (si el plan en UF supera el 7%, el trabajador paga la diferencia, que no es deducible de impuesto)</li>
      <li>Jornada completa legal: 42 hrs (Ley 40 horas, 2026). Jornada parcial = el ingreso mínimo y la hora se calculan proporcionales. Días del mes: tope legal 30</li>
      <li>Horas extra: recargo 50% sobre la hora ordinaria · Atrasos: hora ordinaria, rebajan la base imponible</li>
      <li>Bono líquido: se "embrutece" según las cotizaciones del trabajador y el impuesto marginal (aproximación, validar en bordes de tramo)</li>
      <li>Cesantía trabajador indefinido: ${pct(D.afcTrabajadorIndef)}% · Cesantía empleador: ${pct(D.afcEmpleadorIndef)}% indefinido / ${pct(D.afcEmpleadorPlazo)}% plazo fijo</li>
      <li>Costos empleador: SIS ${pct(D.sis)}% · Capitalización individual ${pct(D.cargoEmpleadorAFP)}% · Expectativa de vida ${pct(D.expectativaVida)}% · Mutual editable (def. 0,93%)</li>
      <li>Impuesto único: tramos en UTM con rebaja (estructura legal estándar)</li>
    </ul><p class="params-nota">Los indicadores se actualizan solos desde Previred cada mes. Falta validar la lógica completa antes de dar de alta (quitar noindex y enlazar al menú).</p>`;
  };

  // Cambios de interfaz
  $('modo').addEventListener('change', () => { $('monto-label').textContent = $('modo').value === 'liquido' ? 'Sueldo líquido deseado' : 'Sueldo base mensual'; calcular(); });
  $('salud-tipo').addEventListener('change', () => { $('isapre-wrap').hidden = $('salud-tipo').value !== 'isapre'; calcular(); });
  $('cw-form').addEventListener('input', calcular);
  $('cw-form').addEventListener('change', calcular);

  llenarAFPs();
  Promise.all([
    fetch('https://mindicador.cl/api/uf').then((r) => r.json()).then((d) => { if (d.serie && d.serie[0]) UF = d.serie[0].valor; }).catch(() => {}),
    fetch('https://mindicador.cl/api/utm').then((r) => r.json()).then((d) => { if (d.serie && d.serie[0]) UTM = d.serie[0].valor; }).catch(() => {}),
    fetch('/api/indicadores-previred').then((r) => r.json()).then((d) => { if (d && d.afps && Object.keys(d.afps).length) D = d; }).catch(() => {}),
  ]).then(() => { llenarAFPs(); calcular(); pintarParams(); });
  calcular(); pintarParams();
</script>

<style>
  .hero{background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%);padding:56px 0 44px}
  .hero h1{font-size:33px;font-weight:800;letter-spacing:-.5px;max-width:22ch}
  .hero .lead{font-size:18px;color:#444a63;margin:16px 0 0;max-width:60ch}
  .sec{padding:40px 0}
  .calc-wrap{max-width:980px}
  .aviso-top{background:#fdf4dd;border:1px solid #f1d98a;border-radius:12px;padding:13px 18px;font-size:14px;color:#6b5b1f;margin-bottom:22px}
  .grid{display:grid;grid-template-columns:1.05fr .95fr;gap:24px;align-items:start}
  .panel{background:#fff;border:1px solid var(--linea);border-radius:18px;padding:26px}
  .panel h2{font-size:16px;font-weight:800;color:var(--azul);margin:4px 0 14px}
  .f{display:block;margin-bottom:14px}.f>span{display:block;font-family:'Montserrat';font-weight:600;font-size:13.5px;color:var(--azul-prof);margin-bottom:6px}
  .f>span em{color:var(--gris);font-weight:500;font-style:normal}
  .f input,.f select{width:100%;border:1px solid var(--linea);border-radius:10px;padding:11px 13px;font-family:inherit;font-size:15px;color:var(--azul-prof);background:#fff}
  .f input:focus,.f select:focus{outline:none;border-color:var(--azul)}
  .f2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .inp{display:flex;align-items:center;border:1px solid var(--linea);border-radius:10px;padding:0 12px}
  .inp:focus-within{border-color:var(--azul)}
  .inp i{font-family:'Montserrat';font-weight:700;color:var(--gris);font-size:14px;font-style:normal}
  .inp i:first-child{margin-right:6px}.inp i:last-child{margin-left:6px}
  .inp input{border:none;padding:11px 0;width:100%}

  .more{margin-top:4px;border-top:1px solid var(--linea);padding-top:12px}
  .more summary{list-style:none;cursor:pointer;font-family:'Montserrat';font-weight:700;font-size:14px;color:var(--azul);display:flex;align-items:center;gap:8px}
  .more summary::-webkit-details-marker{display:none}
  .more .plus{font-size:18px;transition:.2s}.more[open] .plus{transform:rotate(45deg)}
  .more-body{padding-top:16px}

  .result{position:sticky;top:92px;background:linear-gradient(160deg,#fff,#f7f9fe)}
  .dual{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
