---
import Base from '../layouts/Base.astro';
import Sugerencias from '../components/Sugerencias.astro';
import BannerServicios from '../components/BannerServicios.astro';

const seo = {
  title: 'Calculadoras Gratis para Pymes en Chile 2026 · TomContable',
  description: 'Calculadoras gratis para emprendedores y pymes en Chile: sueldo líquido y costo empresa, finiquito, IVA, boleta de honorarios, UF, UTM, dólar e IPC. Al día con datos oficiales y sin registro.',
  canonical: '/herramientas',
};

const tools = [
  {
    t: 'Calculadora de sueldo líquido',
    d: 'Calcula el sueldo líquido desde el bruto, o al revés, con AFP, salud, gratificación, impuesto y el costo real para la empresa.',
    href: '/calculadora-sueldo-liquido',
    ico: '<rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/>',
  },
  {
    t: 'Calculadora de finiquito',
    d: 'Estima tu finiquito en Chile: vacaciones, indemnización por años de servicio y mes de aviso, con la UF al día.',
    href: '/calculadora-finiquito',
    ico: '<path d="M9 12h6M9 16h6M9 8h2"/><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/>',
  },
  {
    t: 'Calculadora de IVA',
    d: 'Agrega el IVA del 19% a un monto neto o sácalo de un total, sin equivocarte con el cálculo al revés.',
    href: '/calculadora-iva',
    ico: '<path d="M19 5L5 19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>',
  },
  {
    t: 'Calculadora de boleta de honorarios',
    d: 'Calcula cuánto recibes líquido tras la retención, o por cuánto emitir tu boleta para recibir el líquido que necesitas.',
    href: '/calculadora-boleta-honorarios',
    ico: '<path d="M6 2h9l5 5v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/><path d="M14 2v5h5"/><path d="M9 13h6M9 17h4"/>',
  },
  {
    t: 'Calculadora UF a pesos',
    d: 'Convierte UF a pesos y pesos a UF con el valor de hoy o de cualquier fecha. Ideal para arriendos, créditos y montos tributarios.',
    href: '/calculadora-uf',
    ico: '<path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/>',
  },
  {
    t: 'Calculadora UTM a pesos',
    d: 'Convierte UTM a pesos con el valor del mes. Útil para entender multas, intereses y cobros del SII expresados en UTM.',
    href: '/calculadora-utm',
    ico: '<path d="M4 7V4h16v3"/><path d="M9 20h6M12 4v16"/>',
  },
  {
    t: 'Calculadora dólar a pesos',
    d: 'Convierte dólares a pesos con el dólar observado oficial, de hoy o de la fecha que elijas, según el Banco Central.',
    href: '/calculadora-dolar',
    ico: '<path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  },
  {
    t: 'Calculadora de reajuste por IPC',
    d: 'Reajusta un arriendo, una deuda o cualquier monto en pesos con la variación oficial del IPC del INE entre dos fechas.',
    href: '/calculadora-ipc',
    ico: '<path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/><path d="M17 7h3v3"/>',
  },
  {
    t: 'Calculadora de IVA en arriendo amoblado',
    d: 'Calcula el IVA de un arriendo amoblado o por días (tipo Airbnb), aplicando la rebaja del 11% del avalúo fiscal proporcional a los días.',
    href: '/calculadora-iva-arriendo-amoblado',
    ico: '<path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/>',
  },
  {
    t: 'Calculadora de multas e intereses del SII',
    d: 'Estima la multa, el reajuste por IPC y el interés diario por declarar o pagar fuera de plazo el IVA o la renta, según el tipo de impuesto.',
    href: '/calculadora-multas-intereses-sii',
    ico: '<rect x="4" y="3" width="13" height="18" rx="2"/><path d="M8 8h5M8 12h4"/><circle cx="17" cy="16" r="4.5"/><path d="M17 14v2.2M17 18.5h.01"/>',
  },
  {
    t: 'Indicadores previsionales',
    d: 'UF, UTM, comisiones de cada AFP, topes imponibles, sueldo mínimo, asignación familiar y más, al día y en un solo lugar.',
    href: '/indicadores-previsionales',
    ico: '<path d="M3 3v18h18"/><path d="M8 17v-5M13 17V8M18 17v-9"/>',
  },
];

const faqs = [
  { q: '¿Las calculadoras de TomContable son gratis?', a: 'Sí. Todas son gratuitas, sin registro y sin límite de uso. Puedes ocuparlas las veces que quieras desde el computador o el celular.' },
  { q: '¿Qué calculadoras hay disponibles?', a: 'Hoy tienes calculadora de sueldo líquido y costo empresa, de finiquito, de IVA, de boleta de honorarios, y conversores de UF, UTM, dólar e IPC a pesos. Vamos sumando más según lo que nos piden.' },
  { q: '¿Los resultados son oficiales?', a: 'Son referenciales. Las conversiones de UF, UTM y dólar usan los valores del Banco Central, y el reajuste por IPC usa la variación oficial del INE. Los cálculos laborales y tributarios son estimaciones hechas con los datos que ingresas, no documentos oficiales.' },
  { q: '¿La calculadora de finiquito reemplaza una revisión profesional?', a: 'No. Te da una estimación rápida, pero el monto final depende del contrato, la causal de término, las remuneraciones y la normativa vigente. Para un finiquito bien hecho conviene revisarlo con un profesional.' },
  { q: '¿La calculadora de sueldo líquido considera el costo empresa?', a: 'Sí. Además del líquido que recibe el trabajador, te muestra el costo real para la empresa, que es lo que de verdad necesitas saber al momento de contratar.' },
  { q: '¿La calculadora de IVA sirve para declarar el F29?', a: 'Te ayuda a calcular rápido el IVA de un monto puntual, pero el F29 reúne todas las ventas y compras del mes. Para presentarlo bien y a tiempo, eso lo vemos en la contabilidad mensual.' },
  { q: '¿Cada cuánto se actualizan los valores de UF, UTM, dólar e IPC?', a: 'La UF cambia todos los días, el dólar observado cada día hábil, la UTM una vez al mes y el IPC lo publica el INE mensualmente. Las calculadoras toman el valor vigente al momento de usarlas.' },
  { q: '¿Puedo usar estas herramientas si soy emprendedor o pyme?', a: 'Para eso están. Las pensamos justo para emprendedores, profesionales independientes y pymes que quieren resolver una duda concreta sin tener que entender toda la letra chica.' },
];

const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Calculadoras gratis para pymes y emprendedores en Chile',
  description: 'Calculadoras gratuitas de TomContable para estimar sueldos, finiquitos, IVA y boletas, y convertir UF, UTM, dólar e IPC a pesos.',
  itemListElement: tools.map((t, i) => ({
    '@type': 'ListItem', position: i + 1, url: 'https://tomcontable.cl' + t.href,
    item: { '@type': 'WebApplication', name: t.t, description: t.d, applicationCategory: 'FinanceApplication', operatingSystem: 'Web', url: 'https://tomcontable.cl' + t.href, offers: { '@type': 'Offer', price: '0', priceCurrency: 'CLP' } },
  })),
};
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((it) => ({ '@type': 'Question', name: it.q, acceptedAnswer: { '@type': 'Answer', text: it.a } })) };
const breadcrumb = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://tomcontable.cl/' },
  { '@type': 'ListItem', position: 2, name: 'Herramientas', item: 'https://tomcontable.cl/herramientas' }
] };

// Agrupación visual de las herramientas. Para sumar una nueva, agrégala a tools y a la categoría que corresponda.
const cats = [
  { titulo: 'Sueldos y trabajo', hrefs: ['/calculadora-sueldo-liquido', '/calculadora-finiquito', '/indicadores-previsionales'] },
  { titulo: 'Impuestos', hrefs: ['/calculadora-iva', '/calculadora-boleta-honorarios', '/calculadora-iva-arriendo-amoblado', '/calculadora-multas-intereses-sii'] },
  { titulo: 'Indicadores y conversores', hrefs: ['/calculadora-uf', '/calculadora-utm', '/calculadora-dolar', '/calculadora-ipc'] },
];
---
<Base {...seo} schema={[listSchema, faqSchema, breadcrumb]}>

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Herramientas</p>
      <h1>Calculadoras gratis para pymes y emprendedores en Chile</h1>
      <p class="lead">Calcula sueldos líquidos, finiquitos, IVA, boletas de honorarios y convierte UF, UTM, dólar e IPC a pesos. Herramientas simples, gratuitas y pensadas para emprendedores y pymes en Chile.</p>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      {cats.map((c) => (
        <div class="cat-bloque">
          <h2 class="cat-titulo">{c.titulo}</h2>
          <div class="grid">
            {tools.filter((t) => c.hrefs.includes(t.href)).map((t) => (
              <a class="card" href={t.href}>
                <span class="ico"><svg viewBox="0 0 24 24" set:html={t.ico} /></span>
                <h3>{t.t}</h3>
                <p>{t.d}</p>
                <span class="card-cta">Abrir →</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="sec sec-texto">
    <div class="wrap angosto">
      <h2>Calculadoras para el día a día de tu negocio</h2>
      <p>Aquí reunimos todas nuestras calculadoras gratuitas, pensadas para emprendedores, profesionales independientes y pymes en Chile. En un solo lugar puedes estimar el sueldo líquido y el costo real de contratar, calcular un finiquito, sacar el IVA de un monto, ver cuánto recibes al emitir una boleta de honorarios y convertir UF, UTM, dólar e IPC a pesos.</p>
      <p>Las hicimos para resolver las dudas que aparecen cuando llevas un negocio: cuánto cuesta sumar a alguien al equipo, cuánto podría salir un finiquito, cómo reajustar un arriendo o una deuda por IPC, o a cuántos pesos equivale un monto pactado en UF. Cada una usa, cuando corresponde, los valores oficiales del Banco Central y del INE, así que siempre trabajas con datos al día.</p>
      <p>Los resultados son referenciales y se calculan con lo que ingresas. No reemplazan la mirada de un contador, pero te ayudan a decidir con más claridad antes de dar el siguiente paso. Y si después quieres dejar la contabilidad de tu empresa ordenada y sin sorpresas, eso es justo lo que hacemos en la <a href="/contabilidad-mensual/">contabilidad mensual</a>.</p>

      <h2 id="faq">Preguntas frecuentes</h2>
      <div class="faq">
        {faqs.map((it) => (
          <details>
            <summary>{it.q}<span class="plus">+</span></summary>
            <div class="ans">{it.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div class="banner-wrap"><BannerServicios /></div>

  <Sugerencias
    titulo="¿Echas de menos una calculadora?"
    subtitulo="Esta web la construimos pensando en ti. Si te falta una calculadora tributaria, laboral, contable o financiera para Chile, cuéntanos qué herramienta te serviría y nos ponemos a trabajar en las que más nos pidan."
    origen="herramientas"
  />

</Base>

<style>
  .hero{background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%);padding:62px 0}
  .hero h1{font-size:40px;font-weight:800;letter-spacing:-.5px;max-width:26ch}
  .hero .lead{font-size:18px;color:#444a63;margin:18px 0 0;max-width:62ch}

  .sec{padding:54px 0}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:22px}
  .card{background:#fff;border:1px solid var(--linea);border-radius:18px;padding:28px;display:flex;flex-direction:column;transition:transform .18s,border-color .18s,box-shadow .18s;box-shadow:0 6px 18px -14px rgba(19,35,95,.4)}
  .card:hover{transform:translateY(-3px);border-color:#c9cfe2;box-shadow:0 16px 30px -18px rgba(19,35,95,.5)}
  .ico{display:inline-flex;align-items:center;justify-content:center;width:46px;height:46px;border-radius:13px;background:var(--amarillo);margin-bottom:14px}
  .ico svg{width:23px;height:23px;fill:none;stroke:var(--azul-prof);stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .card h3{font-size:19px;font-weight:800;margin-bottom:8px}
  .cat-bloque{margin-bottom:40px}
  .cat-bloque:last-child{margin-bottom:0}
  .cat-titulo{font-size:22px;font-weight:800;margin:0 0 18px;letter-spacing:-.3px}
  .card p{font-size:15px;color:#555;flex:1;margin-bottom:16px;line-height:1.6}
  .card-cta{font-family:'Montserrat';font-weight:700;font-size:14px;color:var(--azul)}

  .sec-texto{padding-top:8px}
  .angosto{max-width:760px}
  .sec-texto h2{font-size:24px;font-weight:800;margin:30px 0 12px;letter-spacing:-.3px}
  .sec-texto p{font-size:16px;color:#444a63;line-height:1.7;margin-bottom:14px}
  .sec-texto p a{color:var(--azul);font-weight:600}

  .faq{margin-top:6px}
  details{background:#fff;border:1px solid var(--linea);border-radius:14px;margin-bottom:12px;overflow:hidden}
  summary{list-style:none;cursor:pointer;padding:18px 22px;font-family:'Montserrat';font-weight:600;font-size:16px;color:var(--azul);display:flex;justify-content:space-between;gap:14px}
  summary::-webkit-details-marker{display:none}
  .plus{font-size:22px;color:var(--azul);transition:transform .2s;flex-shrink:0}
  details[open] .plus{transform:rotate(45deg)}
  .ans{padding:0 22px 18px;color:#555;font-size:15.5px;line-height:1.6}

  .banner-wrap{padding:0 24px 48px}
  @media(max-width:880px){ .grid{grid-template-columns:1fr} }
  @media(max-width:640px){ .hero h1{font-size:31px} }
</style>
