---
import Base from '../layouts/Base.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';

const seo = {
  title: 'Servicios contables para pymes y emprendedores · TomContable',
  description: 'Constitución de empresas, contabilidad mensual, operación renta, asesorías, proyección tributaria y ayuda con el SII. Conoce todos los servicios de TomContable.',
};

const servicios = [
  { t: 'Constituir empresa, lista para facturar', d: 'No solo creamos la sociedad: la dejamos iniciada ante el SII y técnicamente lista para emitir tu primera factura.', href: '/constitucion-de-empresas', ico: '<path d="M3 21h18M6 21V8l6-4 6 4v13"/><path d="M10 12h4M10 16h4"/>' },
  { t: 'Contabilidad mensual', d: 'Tus impuestos al día, tus dudas resueltas y alguien mirando tu negocio todos los meses. La operación renta de tu empresa va incluida.', href: '/contabilidad-mensual', ico: '<rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4M9 15l2 2 4-4"/>' },
  { t: 'Problemas con el SII', d: 'IVA o renta observada, bloqueos, citaciones. Revisamos tu situación de los últimos años, encontramos el origen y te decimos qué hacer.', href: '/problemas-con-el-sii', ico: '<path d="M10.3 3.3 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.3a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/>' },
  { t: 'Asesorías tributarias', d: 'Una sesión con un experto que te deja con un plan claro para tu duda puntual, sin tener que contratar un servicio completo.', href: '/asesorias', ico: '<path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.4 8.4 0 0 1-3.9-.9L3 21l1.9-5.6A8.4 8.4 0 0 1 4 11.5 8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"/><path d="M9.6 9a2.5 2.5 0 0 1 4.8.9c0 1.7-2.4 2.3-2.4 2.3M12 16h.01"/>' },
  { t: 'Proyección tributaria', d: 'Antes del cierre del año proyectamos cuánto pagará tu empresa y cada socio, para que decidas a tiempo y llegues a abril sin sorpresas.', href: '/proyeccion-tributaria', ico: '<path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/><path d="M19 7h-3M19 7v3"/>' },
];
---
<Base {...seo}>

  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Servicios</p>
      <h1>Todo lo contable y tributario de tu negocio, en un solo lugar.</h1>
      <p class="lead">Desde que constituyes tu empresa hasta el día a día con el SII, te acompañamos con claridad y sin tecnicismos. Elige el servicio que necesitas o escríbenos y te decimos qué te conviene.</p>
      <div class="cta-row">
        <BotonWhatsApp texto="Hablar por WhatsApp" />
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="serv-grid">
        {servicios.map((s) => (
          <a class="serv" href={s.href}>
            <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24" set:html={s.ico} /></span><h2>{s.t}</h2></div>
            <p>{s.d}</p>
            <span class="more">Ver más
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
        <div class="serv comunidad">
          <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="3.5"/><path d="M22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8"/></svg></span><h2>Comunidad de emprendedores</h2></div>
          <p>Todos nuestros clientes acceden gratis a nuestra comunidad: red de contactos, oportunidades y apoyo de un contador y un abogado.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cierre">
    <div class="wrap">
      <h2>¿No sabes cuál necesitas?</h2>
      <p>Cuéntanos en qué estás y te decimos qué servicio te conviene, claro y sin compromiso.</p>
      <div class="cta-row center">
        <BotonWhatsApp texto="Hablar por WhatsApp" />
      </div>
    </div>
  </section>

</Base>

<style>
  .hero{background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%);padding:64px 0}
  .hero h1{font-size:40px;font-weight:800;max-width:20ch;letter-spacing:-.5px}
  .hero .lead{font-size:18px;color:#444a63;margin:20px 0 26px;max-width:62ch}
  .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .cta-row.center{justify-content:center}

  .serv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
  .serv{background:#fff;border:1px solid var(--linea);border-radius:18px;padding:28px;display:flex;flex-direction:column;transition:.18s}
  .serv:hover{box-shadow:0 18px 40px -20px rgba(19,35,95,.35);transform:translateY(-3px)}
  .serv-head{display:flex;align-items:center;gap:13px;margin-bottom:10px}
  .serv .ico{flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:12px;background:var(--azul)}
  .serv .ico svg{width:22px;height:22px;fill:none;stroke:var(--amarillo);stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .serv-head h2{font-size:18px;font-weight:700;margin:0}
  .serv p{font-size:15px;color:#555;flex:1}
  .serv .more{margin-top:16px;font-family:'Montserrat';font-weight:700;font-size:14.5px;color:var(--azul);display:inline-flex;align-items:center;gap:7px}
  .serv .more svg{width:16px;height:16px;transition:.15s}
  .serv:hover .more svg{transform:translateX(4px)}
  .serv.comunidad{background:linear-gradient(160deg,#eef1fb,#fff)}
  @media(max-width:880px){ .serv-grid{grid-template-columns:1fr} }

  .cierre{background:linear-gradient(150deg,var(--azul),var(--azul-prof));color:#fff;text-align:center;padding:70px 24px}
  .cierre h2{color:#fff;font-size:30px;font-weight:800}
  .cierre p{color:#cfd6ea;font-size:17px;margin:14px auto 28px;max-width:52ch}
  @media(max-width:900px){ .hero h1{font-size:31px} }
<