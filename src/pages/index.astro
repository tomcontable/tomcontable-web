---
// Home 2.0. Reemplazó al home anterior el 2026-07-02 (respaldo en
// Marketing/tomcontable.cl/_respaldos/index-home-v1-2026-07-02.astro.txt).
// Concepto: el visitante llega tibio desde Instagram. La página confirma que
// llegó al lugar correcto y convierte esa confianza en UN paso: WhatsApp.
// Firma visual: "el hilo" (línea dorada que conecta los hitos de la página)
// y el celular que muestra la conversación de WhatsApp junto al mes tipo.
import Base from '../layouts/Base.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';
import MuroTestimonios from '../components/MuroTestimonios.astro';

const seo = {
  title: 'TomContable, Contador para emprendedores y pymes en Chile',
  description: 'Contabilidad clara y cercana para emprendedores y pymes chilenas. Más que contabilidad, tranquilidad. Conversemos por WhatsApp.',
};

const webSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "TomContable",
  "url": "https://tomcontable.cl",
  "inLanguage": "es-CL",
  "publisher": { "@id": "https://tomcontable.cl/#organizacion" }
};

const problemas = [
  {
    frase: 'Quiero partir mi propia empresa',
    resp: 'Te la entregamos constituida, iniciada ante el SII y lista para facturar. Tú eliges el nombre; nosotros hacemos todo lo demás.',
    precio: '$159.900 + IVA',
    nota: 'hasta en 3 cuotas sin interés',
    href: '/constitucion-de-empresas',
    ico: '<path d="M3 21h18M6 21V8l6-4 6 4v13"/><path d="M10 12h4M10 16h4"/>',
  },
  {
    frase: 'Necesito que alguien lleve mi mes',
    resp: 'Nuestro plan principal: F29 y libros al día, reporte claro y asesoría ilimitada por WhatsApp, todos los meses.',
    precio: 'Desde 1 UF + IVA',
    nota: 'al mes, según tu empresa y ventas',
    href: '/contabilidad-mensual',
    destacado: true,
    ico: '<rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4M9 15l2 2 4-4"/>',
  },
  {
    frase: 'El SII me escribió y no sé qué hacer',
    resp: 'Carta, IVA observado, bloqueo o citación: revisamos tu caso, encontramos el origen y te decimos exactamente qué hacer.',
    precio: '3 UF + IVA',
    nota: 'revisión completa de tu situación',
    href: '/problemas-con-el-sii',
    ico: '<path d="M10.3 3.3 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.3a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/>',
  },
  {
    frase: 'Quiero saber cuánto pagaré en abril',
    resp: 'Proyectamos el impuesto de tu empresa y de cada socio con meses de anticipación, cuando todavía puedes tomar decisiones.',
    precio: 'Desde $79.000 + IVA',
    nota: 'antes de que llegue la cuenta',
    href: '/proyeccion-tributaria',
    ico: '<path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/><path d="M19 7h-3M19 7v3"/>',
  },
  {
    frase: 'Tengo una duda puntual',
    resp: 'Una sesión con un experto y sales con un plan claro. Sin contratos largos ni letra chica.',
    precio: 'Desde $35.000',
    nota: 'sesiones de 15, 30 o 60 minutos',
    href: '/asesorias',
    ico: '<path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.4 8.4 0 0 1-3.9-.9L3 21l1.9-5.6A8.4 8.4 0 0 1 4 11.5 8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"/><path d="M9.6 9a2.5 2.5 0 0 1 4.8.9c0 1.7-2.4 2.3-2.4 2.3M12 16h.01"/>',
  },
];

// FAQ visible espejada para FAQPage (las dudas reales antes de que las piensen).
const faqs = [
  { q: '¿Cuánto cuesta la contabilidad mensual?', a: 'Los planes parten en 1 UF + IVA al mes (unos $40.800) y el valor final depende de tu tipo de empresa y tus ventas. Te lo decimos claro y por escrito antes de empezar, sin sorpresas después.' },
  { q: '¿Qué incluye el plan mensual?', a: 'F29 y libros al día, remuneraciones si tienes trabajadores, un reporte mensual que se entiende, asesoría ilimitada por WhatsApp, pre balance en julio y la operación renta incluida como parte del plan anual. Además, acceso gratis a nuestra comunidad de emprendedores.' },
  { q: '¿Qué tan rápido responden?', a: 'Por WhatsApp, en horario hábil, lo antes posible y siempre dentro del día. Una duda puntual no debería esperar una semana: esa es la razón por la que existimos.' },
  { q: 'Ya tengo un problema con el SII, ¿me pueden ayudar igual?', a: 'Sí, es uno de nuestros servicios más pedidos. Revisamos tu situación completa (3 UF + IVA), encontramos el origen del problema y te decimos qué hacer. Muchos de nuestros clientes mensuales llegaron así.' },
  { q: '¿Trabajan con negocios como el mío?', a: 'Atendemos emprendedores, profesionales independientes y pymes de todos los rubros, en todo Chile, 100% online. Si recién estás partiendo o llevas años funcionando, el plan se ajusta a tu momento.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((it) => ({ '@type': 'Question', name: it.q, acceptedAnswer: { '@type': 'Answer', text: it.a } })) };
---
<Base {...seo} schema={[webSite, faqSchema]}>

  <!-- ============ HERO ============ -->
  <section class="h2-hero">
    <div class="wrap h2-hero-grid">
      <div class="h2-hero-txt">
        <a class="h2-puente" href="https://www.instagram.com/tomcontable" target="_blank" rel="noopener">
          <span class="h2-puente-ig" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.3" fill="currentColor" stroke="none"/></svg></span>
          ¿Vienes de Instagram? Llegaste bien: esta es la oficina.
        </a>
        <p class="h2-kicker">Contabilidad para pymes y emprendedores en Chile</p>
        <h1>Tus impuestos en orden.<br />Tu cabeza, <span class="h2-marca">en tu negocio</span>.</h1>
        <p class="h2-lead">Somos el equipo contable detrás de la cuenta que ya sigues. Llevamos tu empresa mes a mes: declaraciones a tiempo, respuestas el mismo día y alguien mirando el detalle antes de que se vuelva multa.</p>
        <p class="h2-lema"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 14.5 9.5 22 12l-7.5 2.5L12 22l-2.5-7.5L2 12l7.5-2.5z"/></svg>Más que contabilidad, tranquilidad.</p>
        <div class="h2-cta-row">
          <BotonWhatsApp texto="Conversemos tu caso" mensaje="Hola Tom, vengo de Instagram y quiero ordenar la contabilidad de mi negocio" />
          <a class="btn btn-ghost" href="#h2-servicios">Ver servicios y precios</a>
        </div>
        <ul class="h2-micro">
          <li>Contador Colegiado</li>
          <li>Más de 12 años de experiencia</li>
          <li>Atendemos todo Chile, 100% online</li>
        </ul>
      </div>

      <!-- La cara real de Tom, para que confirmen que llegaron al lugar correcto -->
