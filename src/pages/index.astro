        <div class="photo-card">
          <img src="/img/foto-tom.jpg" alt="Tom, contador para pymes y emprendedores, fundador de TomContable" width="520" height="390" />
          <div class="photo-badge">
            <span class="stars">★★★★★</span>
            <div><b>5,0</b><br><small>124 evaluaciones</small></div>
          </div>
          <div class="photo-chip"><span class="wa"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/></svg></span>Respondemos por WhatsApp</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PRUEBA SOCIAL ============ -->
  <div class="proof">
    <div class="wrap proof-grid">
      <div><span class="n" data-cifra="5.0" data-dec="1">5,0</span><span class="l">en Encuadrado, 124 evaluaciones</span></div>
      <div><span class="n" data-cifra="300" data-pref="+">+300</span><span class="l">empresas constituidas</span></div>
      <div><span class="n" data-cifra="1000" data-pref="+" data-miles>+1.000</span><span class="l">emprendedores asesorados</span></div>
      <div><span class="n" data-cifra="98" data-suf="K">98K</span><span class="l">en Instagram</span></div>
    </div>
  </div>

  <!-- ============ UN MES CONTIGO ============ -->
  <section class="h2-mes">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Contabilidad mensual, nuestro plan principal</p>
        <h2>Así se ve un mes con nosotros</h2>
