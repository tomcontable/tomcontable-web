---
import Base from '../layouts/Base.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';
import MuroTestimonios from '../components/MuroTestimonios.astro';

const seo = {
  title: 'TomContable, Contador para emprendedores y pymes en Chile',
  description: 'Contabilidad clara y cercana para emprendedores y pymes chilenas. Más que contabilidad, tranquilidad. Conversemos por WhatsApp.',
};

const webSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "TomContable",
  "url": "https://tomcontable.cl",
  "inLanguage": "es-CL",
  "publisher": { "@id": "https://tomcontable.cl/#organizacion" }
};

const servicios = [
  { t: 'Constituye tu empresa, lista para facturar', d: 'No solo creamos la sociedad: la dejamos iniciada ante el SII y técnicamente lista para emitir tu primera factura.', href: '/constitucion-de-empresas', et: '$159.900 + IVA', ico: '<path d="M3 21h18M6 21V8l6-4 6 4v13"/><path d="M10 12h4M10 16h4"/>' },
  { t: 'Contabilidad mensual sin sobresaltos', d: 'Tus impuestos al día, tus dudas resueltas y alguien mirando tu negocio todos los meses.', href: '/contabilidad-mensual', et: 'Desde 0,7 UF + IVA', ico: '<rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4M9 15l2 2 4-4"/>' },
  { t: '¿Tienes un problema con el SII?', d: 'IVA o renta observada, bloqueos, citaciones. Revisamos tu caso, encontramos el origen y te decimos qué hacer.', href: '/problemas-con-el-sii', et: '3 UF + IVA', ico: '<path d="M10.3 3.3 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.3a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/>' },
  { t: 'Asesoría tributaria cuando la necesitas', d: 'Una sesión con un experto que te deja con un plan claro para tu duda puntual.', href: '/asesorias', et: 'Desde $35.000', ico: '<path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.4 8.4 0 0 1-3.9-.9L3 21l1.9-5.6A8.4 8.4 0 0 1 4 11.5 8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"/><path d="M9.6 9a2.5 2.5 0 0 1 4.8.9c0 1.7-2.4 2.3-2.4 2.3M12 16h.01"/>' },
  { t: 'Proyección tributaria antes de abril', d: 'Proyectamos cuánto pagará tu empresa y cada socio, para que decidas a tiempo.', href: '/proyeccion-tributaria', et: 'Desde $79.000 + IVA', ico: '<path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/><path d="M19 7h-3M19 7v3"/>' },
];

// FAQ visible espejada para FAQPage (mantener en sync con el accordion del home).
const faqs = [
  { q: '¿Prestan servicios de contabilidad mensual?', a: 'Sí, es nuestro servicio principal. Llevamos tu contabilidad mes a mes: tus impuestos al día, consultas ilimitadas y alguien mirando tu negocio todos los meses. Los planes comienzan en 0,7 UF + IVA al mes (unos $28.500).' },
  { q: '¿Trabajan con empresas como la mía?', a: 'Trabajamos sobre todo con emprendedores, profesionales independientes y pymes. Si recién estás partiendo o ya tienes años funcionando, igual te podemos ayudar.' },
  { q: '¿Atienden online o presencial?', a: 'Trabajamos online con clientes de todo Chile. Nos coordinamos por WhatsApp y videollamada cuando hace falta.' },
  { q: '¿Cuánto cuesta?', a: 'Depende del servicio. La constitución y las asesorías tienen su valor publicado al contratar. La contabilidad mensual comienza en 0,7 UF + IVA al mes (unos $28.500) y se ajusta a tu tipo de empresa, ventas y necesidades. Te lo decimos claro antes de empezar.' },
  { q: '¿En cuánto responden?', a: 'Por WhatsApp, en horario hábil, lo antes posible. No te vamos a dejar esperando.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((it) => ({ '@type': 'Question', name: it.q, acceptedAnswer: { '@type': 'Answer', text: it.a } })) };
---
<Base {...seo} schema={[webSite, faqSchema]}>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <span class="hero-chip"><span class="dot"></span>Contabilidad online para emprendedores y pymes en Chile</span>
        <h1>Contador para pymes y emprendedores: tus impuestos al día y tú, <span class="hl">tranquilo</span> para crecer.</h1>
        <p class="lead">Nos hacemos cargo de tu contabilidad mes a mes: declaraciones presentadas a tiempo, dudas resueltas por WhatsApp y alguien mirando tu empresa antes de que un detalle se transforme en una multa.</p>
        <p class="lema">Más que contabilidad, tranquilidad.</p>
        <div class="cta-row">
          <BotonWhatsApp texto="Conversemos tu caso" mensaje="Hola vengo desde la portada de la web" />
          <a class="btn btn-ghost" href="#servicios">Ver servicios y precios</a>
        </div>
        <p class="cta-note"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l5 5 9-11"/></svg>Sin compromiso. Te decimos qué necesitas y cuánto cuesta antes de empezar.</p>
        <ul class="micro">
          <li>Contador Colegiado</li>
          <li>Más de 12 años de experiencia</li>
          <li>Atendemos todo Chile, 100% online</li>
        </ul>
      </div>
      <div class="photo-wrap">
        <div class="photo-card">
          <img src="/img/foto-tom.jpg" alt="Tom, contador para pymes y emprendedores, fundador de TomContable" width="520" height="390" />
          <div class="photo-badge">
            <span class="stars">★★★★★</span>
            <div><b>5,0</b><br><small>124 evaluaciones</small></div>
          </div>
          <div class="photo-chip"><span class="wa"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/></svg></span>Respondemos por WhatsApp</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRUEBA SOCIAL -->
  <div class="proof">
    <div class="wrap proof-grid">
      <div><span class="n" data-cifra="5.0" data-dec="1">5,0</span><span class="l">en Encuadrado, 124 evaluaciones</span></div>
      <div><span class="n" data-cifra="300" data-pref="+">+300</span><span class="l">empresas constituidas</span></div>
      <div><span class="n" data-cifra="1000" data-pref="+" data-miles>+1.000</span><span class="l">emprendedores asesorados</span></div>
      <div><span class="n" data-cifra="96" data-suf="K">96K</span><span class="l">en Instagram</span></div>
    </div>
  </div>

  <!-- PROBLEMA -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Si estás emprendiendo, esto te suena</p>
        <h2>No quieres aprender contabilidad. Quieres que esté bien hecha y olvidarte.</h2>
      </div>
      <div class="pain-grid">
        <div class="pain"><p>Llega el día 12 y <b>no sabes si tu F29 quedó presentado</b>, ni a quién preguntarle sin que te cobren por responder.</p></div>
        <div class="pain"><p>Mandas un correo a tu contador y <b>pasan días sin respuesta</b>, justo cuando necesitas decidir algo.</p></div>
        <div class="pain"><p>Te enteras de una <b>observación del SII o una multa</b> cuando ya es tarde, en vez de antes de que pase.</p></div>
      </div>
    </div>
  </section>

  <!-- SOLUCIÓN / DESTACADO CONTABILIDAD MENSUAL -->
  <section class="sec alt" id="servicios">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Nuestro servicio principal</p>
        <h2>Contabilidad mensual, sin sobresaltos.</h2>
        <p>El plan que hace que dejes de pensar en impuestos. Tú te dedicas a vender; nosotros, a que tu parte contable y tributaria esté al día todos los meses.</p>
      </div>
      <div class="feat">
        <div class="feat-main">
          <span class="feat-tag">Lo que más contratan nuestros clientes</span>
          <h3>Todo tu mes contable resuelto por un equipo</h3>
          <p class="sub">Un plan que se ajusta a tu tipo de empresa y tus ventas, con asesoría incluida durante todo el año.</p>
          <ul class="feat-list">
            <li>F29 y libros al día</li>
            <li>Reporte mensual claro</li>
            <li>Asesoría ilimitada por WhatsApp</li>
            <li>Pre balance en julio</li>
            <li>Comunidad premium de emprendedores</li>
            <li>Te avisamos antes de cada vencimiento</li>
          </ul>
        </div>
        <div class="feat-side">
          <div class="feat-price">Desde 0,7 UF + IVA<small>al mes</small></div>
          <p class="feat-eq">aprox. $28.500 al mes</p>
          <BotonWhatsApp texto="Cotizar mi plan" mensaje="Hola vengo desde la portada, quiero cotizar contabilidad mensual" />
          <p class="garantia"><b>Garantía TomContable:</b> si una multa o interés se genera por un error o atraso nuestro, lo pagamos nosotros.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OTROS SERVICIOS -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Servicios</p>
        <h2>¿En qué más te podemos ayudar?</h2>
      </div>
      <div class="serv-grid">
        {servicios.filter((s) => s.href !== '/contabilidad-mensual').map((s) => (
          <a class="serv" href={s.href}>
            <span class="serv-et">{s.et}</span>
            <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24" set:html={s.ico} /></span><h3>{s.t}</h3></div>
            <p>{s.d}</p>
            <span class="more">Ver más
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
        <div class="serv comunidad">
          <span class="serv-et">Gratis para clientes</span>
          <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="3.5"/><path d="M22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8"/></svg></span><h3>Comunidad de emprendedores</h3></div>
          <p>Todos nuestros clientes acceden gratis a nuestra comunidad: red de contactos, oportunidades y apoyo de un contador y un abogado.</p>
        </div>
        <a class="serv consulta" href="https://api.whatsapp.com/send/?phone=56936506297&text=Hola%20vengo%20desde%20la%20portada%2C%20tengo%20una%20duda" target="_blank" rel="noopener" onclick="window.posthog&&window.posthog.capture('whatsapp_click',{cta_texto:'Tarjeta no sé qué necesito',mensaje:'Hola vengo desde la portada, tengo una duda',ubicacion:location.pathname})">
          <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.4 8.4 0 0 1-3.9-.9L3 21l1.9-5.6A8.4 8.4 0 0 1 4 11.5 8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"/></svg></span><h3>¿No sabes qué necesitas?</h3></div>
          <p>Cuéntanos tu situación por WhatsApp y te decimos por dónde partir, sin compromiso.</p>
          <span class="more">Escríbenos
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- POR QUÉ TOMCONTABLE -->
  <section class="sec alt">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Por qué TomContable</p>
        <h2>No vendemos formularios. Vendemos saber que tu empresa está bien.</h2>
        <p>Te ayudamos a cumplir con el SII, a pagar lo justo (ni más ni menos) y a dormir tranquilo sabiendo que hay alguien mirando el tema antes de que se convierta en un problema.</p>
      </div>
      <div class="cards-3">
        <div class="card">
          <div class="card-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h8M8 13h5"/></svg></span><h3>Te explicamos en simple</h3></div>
          <p>Sin tecnicismos ni respuestas de manual. Vas a entender qué pasa con tu empresa y por qué.</p>
        </div>
        <div class="card">
          <div class="card-head"><span class="ico"><svg viewBox="0 0 24 24"><polyline points="13 2 4 14 12 14 11 22 20 10 12 10 13 2"/></svg></span><h3>Respondemos cuando lo necesitas</h3></div>
          <p>Una pregunta puntual no debería esperar una semana. Nuestros clientes mensuales tienen consultas ilimitadas y respondemos rápido por WhatsApp, sin dejarte esperando.</p>
        </div>
        <div class="card">
          <div class="card-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></span><h3>Nos adelantamos</h3></div>
          <p>Miramos tu situación antes de que un detalle se transforme en una multa o una observación del SII.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head"><p class="eyebrow">Cómo funciona</p><h2>Empezar es simple</h2></div>
      <div class="steps">
        <div class="step"><div class="step-head"><span class="num">01</span><h3>Conversamos</h3></div><p>Nos escribes por WhatsApp y nos cuentas tu situación. Sin compromiso.</p></div>
        <div class="step"><div class="step-head"><span class="num">02</span><h3>Te proponemos un plan</h3></div><p>Te decimos qué necesitas, qué incluye y cuánto cuesta, claro y por adelantado.</p></div>
        <div class="step"><div class="step-head"><span class="num">03</span><h3>Nos hacemos cargo</h3></div><p>Tú te enfocas en tu negocio. Nosotros, en que tu parte contable y tributaria esté bien.</p></div>
      </div>
    </div>
  </section>

  <!-- QUIENES SOMOS -->
  <section class="sec alt" id="nosotros">
    <div class="wrap about">
      <div class="about-media">
        <img src="/img/foto-tom.jpg" alt="Tom, fundador de TomContable" width="520" height="390" />
      </div>
      <div>
        <p class="eyebrow">Quiénes somos</p>
        <h2>No contratas solo a Tom. Contratas una forma de trabajar.</h2>
        <p>TomContable nació de la marca personal de Tom, pero hoy es un equipo. Tom es la cara visible y el fundador, Ingeniero Comercial y Contador Colegiado, con más de 12 años ayudando a emprendedores chilenos a ordenar su contabilidad y entender sus impuestos.</p>
        <p>Detrás trabaja un equipo de contadores auditores y profesionales tributarios con experiencia real en impuestos mensuales, optimización de la carga tributaria, operación renta, fiscalizaciones, declaraciones juradas, remuneraciones y problemas con el SII. Tu empresa no depende de una sola persona ni de su agenda.</p>
        <div class="creds">
          <span>Ingeniero Comercial</span>
          <span>Contador Colegiado</span>
          <span>+300 empresas constituidas</span>
          <span>Desde 2014</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <MuroTestimonios />

  <!-- INSTAGRAM -->
  <section class="ig">
    <div class="wrap ig-inner">
      <div class="ig-left">
        <span class="ig-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.3" fill="currentColor" stroke="none"/></svg></span>
        <div>
          <p class="ig-eyebrow">Instagram</p>
          <h2>Explico impuestos en simple a más de 96 mil personas.</h2>
          <p>Si quieres entender de tributación sin tecnicismos, ahí publico seguido.</p>
        </div>
      </div>
      <a class="btn btn-ig ig-btn" href="https://www.instagram.com/tomcontable" target="_blank" rel="noopener"><svg class="ig-glifo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.25" fill="currentColor" stroke="none"/></svg>Seguir en Instagram</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="sec alt" id="faq">
    <div class="wrap">
      <div class="sec-head center"><p class="eyebrow">Preguntas frecuentes</p><h2>Resolvemos tus dudas</h2></div>
      <div class="faq">
        {faqs.map((it, i) => (
          <details open={i === 0}>
            <summary>{it.q}<span class="plus">+</span></summary>
            <div class="ans">{it.a}</div>
          </details>
        ))}
      </div>
      <p class="faq-mas"><a href="/preguntas-frecuentes/">Ver todas las preguntas</a></p>
    </div>
  </section>

  <!-- CIERRE -->
  <section class="cierre">
    <div class="wrap">
      <h2>¿Hablamos?</h2>
      <p>Cuéntanos en qué estás. Sin compromiso y sin tecnicismos: te decimos cómo te podemos ayudar y qué conviene en tu caso.</p>
      <div class="cta-row center">
        <BotonWhatsApp texto="Hablar por WhatsApp" mensaje="Hola vengo desde la portada de la web" />
        <a class="btn btn-ig" href="https://www.instagram.com/tomcontable" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.25" fill="currentColor" stroke="none"/></svg>Síguenos en Instagram</a>
      </div>
    </div>
  </section>

</Base>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fino = window.matchMedia('(pointer: fine)').matches;

  // Tilt 3D sutil en las tarjetas de servicio (solo escritorio)
  if (fino && !reduce) {
    document.querySelectorAll('.serv').forEach((c) => {
      c.addEventListener('mousemove', (e) => {
        const r = c.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        c.style.transform = `translateY(-4px) rotateY(${x * 4}deg) rotateX(${-y * 4}deg)`;
      });
      c.addEventListener('mouseleave', () => { c.style.transform = ''; });
    });
  }

  // Números de la barra de prueba social: entran con un fundido y un leve
  // desplazamiento cuando la barra aparece en pantalla (contenido, sin invadir el hero).
  if (!reduce && 'IntersectionObserver' in window) {
    const enes = [...document.querySelectorAll('.proof .n')];
    const rumbos = ['translate(-30px,0)', 'translate(0,22px)', 'translate(0,22px)', 'translate(30px,0)'];
    enes.forEach((n, i) => { n.style.transform = rumbos[i % rumbos.length]; n.style.opacity = '0'; });
    const vio = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (!e.isIntersecting) return;
        vio.disconnect();
        enes.forEach((n, i) => {
          n.style.transition = `transform .6s cubic-bezier(.22,.8,.25,1.04) ${i * 90}ms, opacity .5s ${i * 90}ms`;
          n.style.transform = '';
          n.style.opacity = '';
          setTimeout(() => { n.style.transition = ''; }, 900 + i * 90);
        });
      });
    }, { threshold: 0.3 });
    const pg = document.querySelector('.proof-grid');
    if (pg) vio.observe(pg);
  }

  // EL HILO: láser amarillo que nace en la foto y atraviesa la home al ritmo del scroll
  if (!reduce && window.matchMedia('(min-width: 1100px)').matches) {
    const NS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(NS, 'svg');
    svg.setAttribute('aria-hidden', 'true');
    svg.style.cssText = 'position:absolute;top:0;left:0;z-index:1;pointer-events:none;overflow:visible';
    const halo = document.createElementNS(NS, 'path');
    halo.setAttribute('fill', 'none'); halo.setAttribute('stroke', 'rgba(246,177,26,.18)'); halo.setAttribute('stroke-width', '7'); halo.setAttribute('stroke-linecap', 'round');
    const linea = document.createElementNS(NS, 'path');
    linea.setAttribute('fill', 'none'); linea.setAttribute('stroke', 'rgba(246,177,26,.65)'); linea.setAttribute('stroke-width', '2.4'); linea.setAttribute('stroke-linecap', 'round');
    const cabeza = document.createElementNS(NS, 'circle');
    cabeza.setAttribute('r', '5'); cabeza.setAttribute('fill', '#F6B11A');
    cabeza.style.filter = 'drop-shadow(0 0 7px rgba(246,177,26,.9))';
    svg.append(halo, linea, cabeza);
    document.body.appendChild(svg);

    let largo = 0;
    const centro = (el, fx, fy) => {
      const r = el.getBoundingClientRect();
      return { x: r.left + window.scrollX + r.width * fx, y: r.top + window.scrollY + r.height * fy };
    };
    function construir() {
      const foto = document.querySelector('.photo-card');
      const proof = document.querySelector('.proof-grid');
      const sg = document.querySelector('.serv-grid');
      const nums = document.querySelectorAll('.step .num');
      const tf = document.querySelector('.tst-foot');
      const fin = document.querySelector('.cierre .btn-wa, .cierre .btn');
      if (!foto || !proof || !sg || nums.length < 3 || !fin) return;
      const pts = [
        centro(foto, 0.5, 0.9),
        centro(proof, 0.5, 0.5),
        centro(sg, 1 / 3, 0.18),
        centro(sg, 2 / 3, 0.82),
        centro(nums[0], 0.5, 0.5),
        centro(nums[1], 0.5, 0.5),
        centro(nums[2], 0.5, 0.5),
        centro(tf || fin, 0.5, 0.5),
        centro(fin, 0.5, 0.1),
      ];
      const doc = document.documentElement;
      svg.setAttribute('width', doc.scrollWidth); svg.setAttribute('height', doc.scrollHeight);
      svg.setAttribute('viewBox', `0 0 ${doc.scrollWidth} ${doc.scrollHeight}`);
      let d = `M ${pts[0].x} ${pts[0].y}`;
      for (let i = 0; i < pts.length - 1; i++) {
        const a = pts[i], b = pts[i + 1];
        const dx = b.x - a.x, dy = b.y - a.y;
        if (Math.abs(dy) >= Math.abs(dx)) d += ` C ${a.x} ${a.y + dy * 0.5}, ${b.x} ${b.y - dy * 0.5}, ${b.x} ${b.y}`;
        else d += ` C ${a.x + dx * 0.5} ${a.y}, ${b.x - dx * 0.5} ${b.y}, ${b.x} ${b.y}`;
      }
      linea.setAttribute('d', d); halo.setAttribute('d', d);
      largo = linea.getTotalLength();
      linea.setAttribute('stroke-dasharray', largo); halo.setAttribute('stroke-dasharray', largo);
      pintar();
    }
    function pintar() {
      if (!largo) return;
      const ini = parseFloat(linea.getAttribute('d').split(' ')[2]);
      const docAlto = document.documentElement.scrollHeight;
      const visto = window.scrollY + window.innerHeight * 0.72;
      const prog = Math.max(0, Math.min(1, (visto - ini) / (docAlto - ini - window.innerHeight * 0.2)));
      const dibujado = largo * prog;
      linea.setAttribute('stroke-dashoffset', largo - dibujado);
      halo.setAttribute('stroke-dashoffset', largo - dibujado);
      const p = linea.getPointAtLength(dibujado);
      cabeza.setAttribute('cx', p.x); cabeza.setAttribute('cy', p.y);
      cabeza.style.opacity = prog > 0.005 && prog < 0.998 ? 1 : 0;
    }
    let raf = null;
    addEventListener('scroll', () => { if (!raf) raf = requestAnimationFrame(() => { pintar(); raf = null; }); }, { passive: true });
    let rto = null;
    addEventListener('resize', () => { clearTimeout(rto); rto = setTimeout(construir, 220); });
    addEventListener('load', () => { construir(); setTimeout(construir, 900); });
    construir();
  }
</script>

