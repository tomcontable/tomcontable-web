---
import Base from '../layouts/Base.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';

const seo = {
  title: 'TomContable, Contador para emprendedores y pymes en Chile',
  description: 'Contabilidad clara y cercana para emprendedores y pymes chilenas. Más que contabilidad, tranquilidad. Conversemos por WhatsApp.',
};

const webSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "TomContable",
  "url": "https://tomcontable.cl"
};

const servicios = [
  { t: 'Constituye tu empresa, lista para facturar', d: 'No solo creamos la sociedad: la dejamos iniciada ante el SII y técnicamente lista para emitir tu primera factura.', href: '/constitucion-de-empresas', ico: '<path d="M3 21h18M6 21V8l6-4 6 4v13"/><path d="M10 12h4M10 16h4"/>' },
  { t: 'Contabilidad mensual sin sobresaltos', d: 'Tus impuestos al día, tus dudas resueltas y alguien mirando tu negocio todos los meses.', href: '/contabilidad-mensual', ico: '<rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4M9 15l2 2 4-4"/>' },
  { t: '¿Tienes un problema con el SII?', d: 'IVA o renta observada, bloqueos, citaciones. Revisamos tu caso, encontramos el origen y te decimos qué hacer.', href: '/problemas-con-el-sii', ico: '<path d="M10.3 3.3 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.3a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/>' },
  { t: 'Asesoría tributaria cuando la necesitas', d: 'Una sesión con un experto que te deja con un plan claro para tu duda puntual.', href: '/asesorias', ico: '<path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.4 8.4 0 0 1-3.9-.9L3 21l1.9-5.6A8.4 8.4 0 0 1 4 11.5 8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"/><path d="M9.6 9a2.5 2.5 0 0 1 4.8.9c0 1.7-2.4 2.3-2.4 2.3M12 16h.01"/>' },
  { t: 'Proyección tributaria antes de abril', d: 'Proyectamos cuánto pagará tu empresa y cada socio, para que decidas a tiempo.', href: '/proyeccion-tributaria', ico: '<path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/><path d="M19 7h-3M19 7v3"/>' },
];
---
<Base {...seo} schema={[webSite]}>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <h1>Deja tus impuestos en orden y enfócate en hacer crecer tu negocio.</h1>
        <p class="lead">Somos el contador de cientos de emprendedores y pymes en Chile. Llevamos tu contabilidad al día, te respondemos cuando tienes dudas y nos adelantamos a los problemas antes de que lleguen. Más que contabilidad, tranquilidad.</p>
        <div class="cta-row">
          <BotonWhatsApp texto="Hablar por WhatsApp" />
          <a class="btn btn-ghost" href="#servicios">Ver servicios</a>
        </div>
        <ul class="micro">
          <li>Respondemos por WhatsApp en horario hábil</li>
          <li>Contador Colegiado</li>
          <li>Más de 12 años de experiencia</li>
        </ul>
      </div>
      <div class="photo-wrap">
        <div class="photo-card">
          <img src="/img/foto-tom.png" alt="Tom, fundador de TomContable" width="520" height="420" />
          <div class="photo-badge">
            <span class="stars">★★★★★</span>
            <div><b>4,9</b><br><small>152 reseñas</small></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRUEBA SOCIAL -->
  <div class="proof">
    <div class="wrap proof-grid">
      <div><span class="n">4,<em>9</em></span><span class="l">en Encuadrado, más de 150 reseñas</span></div>
      <div><span class="n">+300</span><span class="l">empresas constituidas</span></div>
      <div><span class="n">+1.000</span><span class="l">emprendedores asesorados</span></div>
      <div><span class="n">96K</span><span class="l">en Instagram</span></div>
    </div>
  </div>

  <!-- VALOR -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Por qué TomContable</p>
        <h2>No vendemos formularios. Vendemos saber que tu empresa e impuestos están bien.</h2>
        <p>La mayoría de los emprendedores no quiere aprender contabilidad. Quiere invertir su tiempo en hacer crecer su negocio y dormir tranquilo sabiendo que sus impuestos están presentados, que cumple con el SII y que hay alguien mirando el tema antes de que se convierta en un problema. Y de paso, te ayudamos a optimizar tu carga tributaria para que pagues lo justo, ni más ni menos.</p>
      </div>
      <div class="cards-3">
        <div class="card">
          <div class="card-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h8M8 13h5"/></svg></span><h3>Te explicamos en simple</h3></div>
          <p>Sin tecnicismos ni respuestas de manual. Vas a entender qué pasa con tu empresa y por qué.</p>
        </div>
        <div class="card">
          <div class="card-head"><span class="ico"><svg viewBox="0 0 24 24"><polyline points="13 2 4 14 12 14 11 22 20 10 12 10 13 2"/></svg></span><h3>Te respondemos cuando lo necesitas</h3></div>
          <p>Una pregunta puntual no debería esperar una semana. Nuestros clientes mensuales tienen consultas ilimitadas y respondemos rápido por WhatsApp, sin dejarte esperando.</p>
        </div>
        <div class="card">
          <div class="card-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></span><h3>Nos adelantamos</h3></div>
          <p>Miramos tu situación antes de que un detalle se transforme en una multa o una observación del SII.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="sec alt" id="servicios">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">Servicios</p>
        <h2>¿En qué te podemos ayudar?</h2>
      </div>
      <div class="serv-grid">
        {servicios.map((s) => (
          <a class="serv" href={s.href}>
            <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24" set:html={s.ico} /></span><h3>{s.t}</h3></div>
            <p>{s.d}</p>
            <span class="more">Ver más
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
        <div class="serv comunidad">
          <div class="serv-head"><span class="ico"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="3.5"/><path d="M22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8"/></svg></span><h3>Comunidad de emprendedores</h3></div>
          <p>Todos nuestros clientes acceden gratis a nuestra comunidad: red de contactos, oportunidades y apoyo de un contador y un abogado.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head"><p class="eyebrow">Cómo funciona</p><h2>Empezar es simple</h2></div>
      <div class="steps">
        <div class="step"><div class="step-head"><span class="num">1</span><h3>Conversamos</h3></div><p>Nos escribes por WhatsApp y nos cuentas tu situación. Sin compromiso.</p></div>
        <div class="step"><div class="step-head"><span class="num">2</span><h3>Te proponemos un plan</h3></div><p>Te decimos qué necesitas, qué incluye y cuánto cuesta, claro y por adelantado.</p></div>
        <div class="step"><div class="step-head"><span class="num">3</span><h3>Nos hacemos cargo</h3></div><p>Tú te enfocas en tu negocio. Nosotros, en que tu parte contable y tributaria esté bien.</p></div>
      </div>
    </div>
  </section>

  <!-- QUIENES SOMOS -->
  <section class="sec alt" id="nosotros">
    <div class="wrap about">
      <div class="about-media">
        <img src="/img/foto-tom.png" alt="Tom, fundador de TomContable" width="520" height="420" />
        <span class="video-tag">Video de presentación, próximamente</span>
      </div>
      <div>
        <p class="eyebrow">Quiénes somos</p>
        <h2>No contratas solo a Tom. Contratas una forma de trabajar.</h2>
        <p>TomContable nació de la marca personal de Tom, pero hoy es un equipo. Tom es la cara visible y el fundador, Ingeniero Comercial y Contador Colegiado, con más de 12 años ayudando a emprendedores chilenos a ordenar su contabilidad y entender sus impuestos.</p>
        <p>Detrás trabaja un equipo de contadores auditores y profesionales tributarios con experiencia real en impuestos mensuales, optimización de la carga tributaria, operación renta, fiscalizaciones, declaraciones juradas, remuneraciones y problemas con el SII. Tu empresa no depende de una sola persona ni de su agenda.</p>
        <div class="creds">
          <span>Ingeniero Comercial</span>
          <span>Contador Colegiado</span>
          <span>+300 empresas constituidas</span>
          <span>Desde 2014</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head"><p class="eyebrow">Testimonios</p><h2>Lo que dicen quienes ya trabajan con nosotros</h2></div>
      <div class="cards-3">
        <div class="tst"><span class="stars">★★★★★</span><p>"Muy claro, preciso, y lo principal es que al transmitir su conocimiento genera tranquilidad, que es justo lo que busco en un profesional que asesora en temas contables y tributarios. Totalmente recomendable."</p><span class="who">Andrea Díaz</span></div>
        <div class="tst"><span class="stars">★★★★★</span><p>"Muy buen feedback, entendieron todas mis dudas y me dieron todas las opciones para resolver mis preocupaciones tributarias, demostrando amplio conocimiento en el ámbito contable. Asesorías que a veces cuesta conseguir. Gracias."</p><span class="who">Mónica Jiménez</span></div>
        <div class="tst"><span class="stars">★★★★★</span><p>"Recomiendo totalmente los servicios de Tom y de su equipo. Explica de forma muy clara y amable todas las dudas y consultas de contabilidad."</p><span class="who">Daniel del Río</span></div>
      </div>
      <p class="tst-foot">Estas y más de 150 reseñas en <a href="https://encuadrado.com/p/tomcontable" target="_blank" rel="noopener">Encuadrado</a>, con 4,9 de 5.</p>
    </div>
  </section>

  <!-- INSTAGRAM -->
  <section class="ig">
    <div class="wrap ig-inner">
      <div>
        <p class="ig-eyebrow">Instagram</p>
        <h2>Explico impuestos en simple a más de 96 mil personas.</h2>
        <p>Si quieres entender de tributación sin tecnicismos, ahí publico seguido.</p>
      </div>
      <a class="btn btn-amber" href="https://www.instagram.com/tomcontable" target="_blank" rel="noopener">Seguir en Instagram</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="sec alt" id="faq">
    <div class="wrap">
      <div class="sec-head center"><p class="eyebrow">Preguntas frecuentes</p><h2>Resolvemos tus dudas</h2></div>
      <div class="faq">
        <details open><summary>¿Prestan servicios de contabilidad mensual?<span class="plus">+</span></summary><div class="ans">Sí, es nuestro servicio principal. Llevamos tu contabilidad mes a mes: tus impuestos al día, consultas ilimitadas y alguien mirando tu negocio todos los meses. Los planes comienzan en 0,7 UF + IVA al mes.</div></details>
        <details><summary>¿Trabajan con empresas como la mía?<span class="plus">+</span></summary><div class="ans">Trabajamos sobre todo con emprendedores, profesionales independientes y pymes. Si recién estás partiendo o ya tienes años funcionando, igual te podemos ayudar.</div></details>
        <details><summary>¿Atienden online o presencial?<span class="plus">+</span></summary><div class="ans">Trabajamos online con clientes de todo Chile. Nos coordinamos por WhatsApp y videollamada cuando hace falta.</div></details>
        <details><summary>¿Cuánto cuesta?<span class="plus">+</span></summary><div class="ans">Depende del servicio. La constitución y las asesorías tienen su valor publicado al contratar. La contabilidad mensual comienza en 0,7 UF + IVA al mes y se ajusta a tu tipo de empresa, ventas y necesidades. Te lo decimos claro antes de empezar.</div></details>
        <details><summary>¿En cuánto responden?<span class="plus">+</span></summary><div class="ans">Por WhatsApp, en horario hábil, lo antes posible. No te vamos a dejar esperando.</div></details>
      </div>
      <p class="faq-mas"><a href="/preguntas-frecuentes">Ver todas las preguntas</a></p>
    </div>
  </section>

  <!-- CIERRE -->
  <section class="cierre">
    <div class="wrap">
      <h2>¿Hablamos?</h2>
      <p>Cuéntanos en qué estás. Sin compromiso y sin tecnicismos: te decimos cómo te podemos ayudar y qué conviene en tu caso.</p>
      <div class="cta-row center">
        <BotonWhatsApp texto="Hablar por WhatsApp" />
        <a class="btn btn-amber" href="https://www.instagram.com/tomcontable" target="_blank" rel="noopener">Síguenos en Instagram</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .hero{background:linear-gradient(150deg,#fbfcfe 0%, #eef1f8 100%)}
  .hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center;padding:72px 24px 80px}
  .hero h1{font-size:46px;font-weight:800;letter-spacing:-.5px}
  .hero .lead{font-size:19px;color:#444a63;margin:22px 0 30px;max-width:34ch}
  .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .cta-row.center{justify-content:center}
  .micro{list-style:none;margin-top:22px;display:flex;gap:18px;flex-wrap:wrap;font-size:13.5px;color:var(--gris)}
  .micro li{position:relative;padding-left:20px}
  .micro li::before{content:"";position:absolute;left:0;top:6px;width:11px;height:6px;border-left:2px solid var(--verde);border-bottom:2px solid var(--verde);transform:rotate(-45deg)}
  .photo-card{position:relative;border-radius:26px;background:linear-gradient(160deg,var(--azul),var(--azul-prof));padding:18px;box-shadow:0 26px 60px -22px rgba(19,35,95,.55)}
  .photo-card img{width:100%;border-radius:16px;height:auto}
  .photo-badge{position:absolute;left:-16px;bottom:24px;background:#fff;border-radius:14px;padding:11px 15px;box-shadow:0 12px 30px -10px rgba(0,0,0,.25);display:flex;gap:10px;align-items:center}
  .photo-badge b{font-family:'Montserrat';color:var(--azul);font-size:20px;line-height:1}
  .photo-badge small{color:var(--gris);font-size:12px}
  @media(max-width:960px){ .hero-grid{grid-template-columns:1fr;gap:34px;padding:48px 24px 56px} .hero h1{font-size:34px} .photo-card{max-width:420px;margin:0 auto} }

  .proof{background:var(--azul);color:#fff}
  .proof-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;padding:38px 24px;text-align:center}
  .proof .n{font-family:'Montserrat';font-weight:800;font-size:38px;display:block;color:var(--amarillo);line-height:1.05}
  .proof .n em{color:var(--amarillo);font-style:normal}
  .proof .l{font-size:13px;color:#c7cee6;margin-top:4px;display:block}
  @media(max-width:680px){ .proof .n{font-size:32px} }
  @media(max-width:680px){ .proof-grid{grid-template-columns:repeat(2,1fr);gap:24px} }

  .cards-3{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:38px}
  .card{background:#fff;border:1px solid var(--linea);border-radius:16px;padding:26px;border-top:3px solid var(--azul)}
  .card-head{display:flex;align-items:center;gap:14px;margin-bottom:10px}
  .card .ico{flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;width:46px;height:46px;border-radius:13px;background:#eef2fb}
  .card .ico svg{width:23px;height:23px;fill:none;stroke:var(--azul);stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .card-head h3{font-size:18px;margin:0}
  .card p{font-size:15px;color:#555}
  @media(max-width:820px){ .cards-3{grid-template-columns:1fr} }

  .serv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:38px}
  .serv{background:#fff;border:1px solid var(--linea);border-radius:18px;padding:28px;display:flex;flex-direction:column;transition:.18s}
  .serv:hover{box-shadow:0 18px 40px -20px rgba(19,35,95,.35);transform:translateY(-3px)}
  .serv-head{display:flex;align-items:center;gap:13px;margin-bottom:10px}
  .serv .ico{flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:12px;background:#eef2fb}
  .serv .ico svg{width:22px;height:22px;fill:none;stroke:var(--azul);stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .serv-head h3{font-size:18px;margin:0}
  .serv p{font-size:15px;color:#555;flex:1}
  .serv .more{margin-top:16px;font-family:'Montserrat';font-weight:700;font-size:14.5px;color:var(--azul);display:inline-flex;align-items:center;gap:7px}
  .serv .more svg{width:16px;height:16px;transition:.15s}
  .serv:hover .more svg{transform:translateX(4px)}
  .serv.comunidad{background:linear-gradient(160deg,#eef1fb,#fff)}
  @media(max-width:880px){ .serv-grid{grid-template-columns:1fr} }

  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px}
  .step{padding:28px;border-radius:16px;background:#fff;border:1px solid var(--linea)}
  .step-head{display:flex;align-items:center;gap:14px;margin-bottom:10px}
  .step .num{flex-shrink:0;font-family:'Montserrat';font-weight:800;font-size:15px;color:var(--verde);background:#eaf6ef;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center}
  .step-head h3{font-size:18px;margin:0}
  .step p{font-size:15px;color:#555}
  @media(max-width:820px){ .steps{grid-template-columns:1fr} }

  .about{display:grid;grid-template-columns:.9fr 1.1fr;gap:50px;align-items:center}
  .about-media{text-align:center}
  .about-media img{width:100%;border-radius:20px;border:1px solid var(--linea);height:auto}
  .video-tag{display:inline-flex;align-items:center;gap:8px;margin-top:14px;background:#fff;border:1px solid var(--linea);color:var(--azul);font-size:12.5px;font-family:'Montserrat';font-weight:600;padding:8px 14px;border-radius:30px}
  .video-tag::before{content:"";width:9px;height:9px;border-radius:50%;background:var(--amarillo)}
  .creds{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}
  .creds span{background:#fff;border:1px solid var(--linea);border-radius:30px;padding:8px 14px;font-size:13.5px;color:var(--azul);font-weight:600}
  @media(max-width:880px){ .about{grid-template-columns:1fr;gap:30px} }

  .tst{background:#fff;border:1px solid var(--linea);border-radius:16px;padding:26px}
  .tst .stars{display:block;margin-bottom:12px}
  .tst p{font-size:15.5px;color:#3a3f50;font-style:italic;margin-bottom:16px}
  .tst .who{font-family:'Montserrat';font-weight:700;font-size:14px;color:var(--azul);display:block}
  .tst .when{font-size:12.5px;color:var(--gris)}
  .tst-foot{text-align:center;margin-top:26px;color:var(--gris);font-size:15px}
  .tst-foot a{color:var(--azul);font-weight:600}

  .sec-head.center{margin:0 auto;text-align:center}
  .faq{max-width:780px;margin:34px auto 0}
  details{background:#fff;border:1px solid var(--linea);border-radius:14px;margin-bottom:12px;overflow:hidden}
  summary{list-style:none;cursor:pointer;padding:20px 24px;font-family:'Montserrat';font-weight:600;font-size:16.5px;color:var(--azul);display:flex;justify-content:space-between;align-items:center;gap:14px}
  summary::-webkit-details-marker{display:none}
  .plus{font-size:22px;color:var(--verde);transition:.2s}
  details[open] .plus{transform:rotate(45deg)}
  .ans{padding:0 24px 20px;color:#555;font-size:15.5px}
  .faq-mas{text-align:center;margin-top:18px}
  .faq-mas a{color:var(--azul);font-weight:700;font-family:'Montserrat'}

  .ig{background:var(--azul);color:#fff;padding:46px 0}
  .ig-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
  .ig-eyebrow{font-family:'Montserrat';font-weight:700;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--amarillo);margin-bottom:8px}
  .ig h2{color:#fff;font-size:26px;font-weight:800;max-width:22ch}
  .ig p{color:#cfd6ea;font-size:16px;margin-top:8px}
  .cierre{background:linear-gradient(150deg,var(--azul),var(--azul-prof));color:#fff;text-align:center;padding:74px 24px}
  .cierre h2{color:#fff;font-size:33px;font-weight:800}
  .cierre p{color:#cfd6ea;font-size:17px;margin:16px auto 30px;max-width:54ch}
</style>
