---
// Puente honesto entre los fondos concursables y los servicios de TomContable.
// Casi todos estos fondos exigen inicio de actividades, empresa formalizada,
// contabilidad al dia o estar sin deudas con el SII. Eso es justo lo que hacemos.
// Reutilizable en el listado y en cada ficha. La prop "compacto" reduce el bloque
// para la ficha (donde ya hay mucho contenido).
const { compacto = false, titulo, bajada } = Astro.props;

const puntos = [
  {
    req: 'Casi todos piden inicio de actividades o empresa formalizada',
    servicio: 'Te dejamos con inicio de actividades o tu empresa constituida y lista para postular.',
    cta: 'Iniciar actividades o constituir',
    href: '/constitucion-de-empresas',
    icono: 'M3 21h18M5 21V7l8-4v18M19 21V11l-6-3M9 9h.01M9 12h.01M9 15h.01',
  },
  {
    req: 'Varios exigen la contabilidad al día y sin deudas',
    servicio: 'Llevamos tu IVA, F29 y remuneraciones al día, para que llegues a postular sin observaciones.',
    cta: 'Ordenar mi contabilidad',
    href: '/contabilidad-mensual',
    icono: 'M9 17V7m4 10V4m4 13v-6M4 21h16',
  },
  {
    req: '¿Tienes una carta, un IVA observado o un bloqueo del SII?',
    servicio: 'Regularizamos tu situación tributaria antes de que te deje fuera de la postulación.',
    cta: 'Revisar mi caso con el SII',
    href: '/problemas-con-el-sii',
    icono: 'M12 9v4m0 4h.01M10.29 3.86l-8.48 14.7A2 2 0 003.53 21h16.94a2 2 0 001.72-3.44l-8.48-14.7a2 2 0 00-3.42 0z',
  },
];

const waMsg = encodeURIComponent('Hola, quiero postular a un fondo y necesito ayuda para cumplir los requisitos (empresa, contabilidad o SII).');
---
<section class={`cf ${compacto ? 'cf-mini' : ''}`} aria-label="Cómo te ayuda TomContable a postular">
  <div class="cf-box">
    <div class="cf-head">
      <span class="cf-eyebrow">Llega a postular con todo en regla</span>
      <h2>{titulo ?? '¿Te falta algo para postular? Nosotros lo dejamos listo'}</h2>
      <p>{bajada ?? 'Estos fondos no los tramita TomContable, pero casi ninguno se puede postular sin la empresa formalizada, la contabilidad al día y la situación tributaria sin observaciones. En eso sí te acompañamos, para que el subsidio no se te escape por un requisito administrativo.'}</p>
    </div>

    <div class="cf-grid">
      {puntos.map((p) => (
        <a class="cf-card" href={p.href}>
          <span class="cf-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={p.icono} /></svg>
          </span>
          <p class="cf-req">{p.req}</p>
          <p class="cf-serv">{p.servicio}</p>
          <span class="cf-link">{p.cta}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
      ))}
    </div>

    <div class="cf-foot">
      <a class="cf-wa" href={`https://api.whatsapp.com/send/?phone=56936506297&text=${waMsg}`} target="_blank" rel="noopener" onclick="window.posthog&&window.posthog.capture('whatsapp_click',{cta_texto:'CTA fondos',ubicacion:location.pathname})">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.523 5.263l-.999 3.648 3.966-1.041zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        Cuéntame tu caso por WhatsApp
      </a>
      <span class="cf-nota">Respuesta el mismo día · Primera orientación sin costo</span>
    </div>
  </div>
</section>

<style>
  .cf{margin:0 auto}
  .cf-box{background:linear-gradient(160deg,var(--azul) 0%, var(--azul-prof) 100%);border-radius:22px;padding:44px 40px;color:#fff;position:relative;overflow:hidden;box-shadow:0 30px 60px -30px rgba(19,35,95,.7)}
  .cf-box::after{content:"";position:absolute;top:-60px;right:-60px;width:260px;height:260px;background:radial-gradient(circle,rgba(246,177,26,.22),transparent 70%);pointer-events:none}
  .cf-head{max-width:640px;position:relative;z-index:1}
  .cf-eyebrow{display:inline-block;font-family:'Montserrat';font-weight:700;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--amarillo);margin-bottom:12px}
  .cf-head h2{color:#fff;font-size:27px;font-weight:800;line-height:1.2;letter-spacing:-.3px;text-wrap:balance}
  .cf-head p{color:#c7cfe8;font-size:15.5px;line-height:1.6;margin-top:14px}

  .cf-grid{position:relative;z-index:1;display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:32px 0 28px}
  .cf-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);border-radius:15px;padding:22px;display:flex;flex-direction:column;transition:background .18s,border-color .18s,transform .18s;backdrop-filter:blur(2px);touch-action:manipulation}
  .cf-card:hover{background:rgba(255,255,255,.12);border-color:var(--amarillo);transform:translateY(-3px)}
  .cf-card:focus-visible{outline:2px solid var(--amarillo);outline-offset:3px}
  .cf-ic{width:42px;height:42px;border-radius:11px;background:var(--amarillo);color:var(--azul-prof);display:flex;align-items:center;justify-content:center;margin-bottom:14px}
  .cf-ic svg{width:22px;height:22px}
  .cf-req{font-family:'Montserrat';font-weight:700;font-size:14.5px;color:#fff;line-height:1.35;margin-bottom:8px}
  .cf-serv{font-size:13.5px;color:#c7cfe8;line-height:1.55;flex-grow:1}
  .cf-link{margin-top:16px;display:inline-flex;align-items:center;gap:7px;font-family:'Montserrat';font-weight:700;font-size:13.5px;color:var(--amarillo)}
  .cf-link svg{width:15px;height:15px;transition:transform .18s}
  .cf-card:hover .cf-link svg{transform:translateX(4px)}

  .cf-foot{position:relative;z-index:1;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
  .cf-wa{display:inline-flex;align-items:center;gap:10px;background:var(--verde);color:#fff;font-family:'Montserrat';font-weight:700;font-size:15px;padding:14px 24px;border-radius:12px;transition:background .16s,transform .16s;box-shadow:0 12px 26px -12px rgba(30,158,87,.7);touch-action:manipulation}
  .cf-wa:hover{background:var(--verde-h);transform:translateY(-1px)}
  .cf-wa:focus-visible{outline:2px solid var(--amarillo);outline-offset:3px}
  .cf-wa svg{width:20px;height:20px}
  .cf-nota{font-size:13px;color:#aeb8d6}

  .cf-mini .cf-box{padding:32px 28px;border-radius:18px}
  .cf-mini .cf-head h2{font-size:22px}
  .cf-mini .cf-grid{grid-template-columns:1fr;gap:12px;margin:24px 0 22px}
  .cf-mini .cf-card{flex-direction:row;align-items:center;gap:16px;padding:16px 18px}
  .cf-mini .cf-ic{margin-bottom:0;flex-shrink:0}
  .cf-mini .cf-req{margin-bottom:2px}
  .cf-mini .cf-serv{display:none}
  .cf-mini .cf-link{margin-top:0;margin-left:auto;flex-shrink:0}

  @media(max-width:860px){
    .cf-grid{grid-template-columns:1fr}
    .cf-box{padding:34px 24px}
    .cf-head h2{font-size:23px}
  }
  @media(max-width:560px){
    .cf-mini .cf-card{flex-direction:column;align-items:flex-start}
    .cf-mini .cf-serv{display:block}
    .cf-mini .cf-link{margin-left:0}
  }
</style>
