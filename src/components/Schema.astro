---
// Inyecta JSON-LD. Cada pagina puede pasar uno o varios bloques de schema.
// Por defecto incluye la organizacion en todas las paginas.
const { blocks = [] } = Astro.props;

const organizacion = {
  "@context": "https://schema.org",
  "@type": ["Organization", "ProfessionalService", "AccountingService"],
  "@id": "https://tomcontable.cl/#organizacion",
  "name": "TomContable",
  "url": "https://tomcontable.cl",
  "logo": "https://tomcontable.cl/img/logo-tomcontable.png",
  "image": "https://tomcontable.cl/img/og-tomcontable.jpg",
  "description": "Empresa contable chilena especializada en emprendedores y pymes. Constitución de empresas, contabilidad mensual, operación renta, asesorías y ayuda con el SII.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Providencia",
    "addressRegion": "Región Metropolitana",
    "addressCountry": "CL"
  },
  "priceRange": "$$",
  "knowsAbout": ["Contabilidad para pymes", "Impuestos en Chile", "IVA y F29", "Operación renta", "Constitución de empresas", "Problemas con el SII", "Remuneraciones", "Boleta de honorarios"],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Atención a clientes",
    "telephone": "+56936506297",
    "email": "hola@tomcontable.cl",
    "areaServed": "CL",
    "availableLanguage": "Spanish"
  },
  "areaServed": { "@type": "Country", "name": "Chile" },
  "founder": {
    "@type": "Person",
    "@id": "https://tomcontable.cl/#tomas",
    "name": "Tomás Gómez Fuenzalida",
    "jobTitle": "Fundador, Contador Colegiado",
    "image": "https://tomcontable.cl/img/foto-tom.jpg",
    "description": "Ingeniero Comercial y Contador Colegiado con más de 12 años ayudando a emprendedores y pymes chilenas a ordenar su contabilidad y entender sus impuestos en simple.",
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "Contador Colegiado"
    },
    "knowsAbout": ["Contabilidad", "Impuestos en Chile", "IVA", "Operación renta", "Constitución de empresas", "SII", "Remuneraciones", "Pymes y emprendedores"],
    "worksFor": { "@id": "https://tomcontable.cl/#organizacion" },
    "sameAs": ["https://www.instagram.com/tomcontable"]
  },
  "email": "hola@tomcontable.cl",
  "telephone": "+56936506297",
  "sameAs": [
    "https://www.instagram.com/tomcontable",
    "https://encuadrado.com/p/tomcontable",
    "https://maps.app.goo.gl/Nrhj9j1CUm3mL71b7"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "124",
    "bestRating": "5",
    "worstRating": "1"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de TomContable",
    "itemListElement": [
      { "@type": "OfferCatalog", "name": "Constitución de empresas", "url": "https://tomcontable.cl/constitucion-de-empresas" },
      { "@type": "OfferCatalog", "name": "Contabilidad mensual", "url": "https://tomcontable.cl/contabilidad-mensual" },
      { "@type": "OfferCatalog", "name": "Problemas con el SII y revisión tributaria", "url": "https://tomcontable.cl/problemas-con-el-sii" },
      { "@type": "OfferCatalog", "name": "Asesorías tributarias", "url": "https://tomcontable.cl/asesorias" },
      { "@type": "OfferCatalog", "name": "Proyección tributaria", "url": "https://tomcontable.cl/proyeccion-tributaria" }
    ]
  }
};

const all = [organizacion, ...blocks];
---
{all.map((b) => (
  <script type="application/ld+json" set:html={JSON.stringify(b)} />
))}
