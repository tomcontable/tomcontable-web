---
// Botón flotante de WhatsApp que aparece después de que el usuario scrollea el 50% de la página.
// Solo en mobile/tablet; en desktop es demasiado invasivo.
const {
  mensaje = 'Hola vengo desde la web',
} = Astro.props;

const href = `https://api.whatsapp.com/send/?phone=56964933110&text=${encodeURIComponent(mensaje)}`;
---
<a class="wa-flotante" href={href} target="_blank" rel="noopener" data-msg={mensaje} onclick="window.posthog&&window.posthog.capture('whatsapp_flotante_click',{mensaje:this.dataset.msg,ubicacion:location.pathname})" title="Hablar por WhatsApp">
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.523 5.263l-.999 3.648 3.966-1.041zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
  </svg>
</a>

<script>
  // Solo muestra en viewport < 1100px (mobile/tablet)
  // Aparece cuando el usuario scrollea más del 50% de la página
  const flotante = document.querySelector('.wa-flotante');
  if (!flotante) {
    // elemento no existe, no hacer nada
  } else {
    const mostrar = () => {
      const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      const enMobile = window.matchMedia('(max-width: 1099px)').matches;
      if (scrollPercent > 50 && enMobile) {
        flotante.classList.add('visible');
      } else {
        flotante.classList.remove('visible');
      }
    };

    window.addEventListener('scroll', mostrar, { passive: true });
    mostrar(); // check inicial
  }
</script>

<style>
  .wa-flotante {
    position: fixed;
    bottom: 24px;
    right: 20px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--verde);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(34, 177, 76, 0.4);
    z-index: 35;
    opacity: 0;
    visibility: hidden;
    transform: translateY(24px);
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    text-decoration: none;
  }

  .wa-flotante svg {
    width: 28px;
    height: 28px;
  }

  .wa-flotante.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .wa-flotante:hover {
    transform: scale(1.1);
  }

  @media (min-width: 1100px) {
    .wa-flotante {
      display: none;
    }
  }
</style>
